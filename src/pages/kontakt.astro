---
import MainLayout from "../layouts/MainLayout.astro"
import ContactFormCard from "../components/ContactFormCard.astro"
import ContactDirectCard from "../components/ContactDirectCard.astro"
import LocationSection from "../components/LocationSection.astro";
import CircleImageHero from "../components/CircleImageHero.astro";

---

<MainLayout
  title="Kontakt – Dein Projekt beginnt hier | maxWapp"
  seoTitle={"Kontaktiere maxWapp – Webdesign & Branding aus München"}
  seoDesc={"Melde dich für ein unverbindliches Gespräch. High-Conversion Webdesign, Branding & Analyse von Juri Lorenz – maxWapp München."}
>
  <!-- Hintergrund mit Verlauf -->
  <div
    class="min-h-screen text-white text-center flex flex-col items-center justify-center"
  >
    <div class="mt-8 md:mt-24"></div>

<CircleImageHero
  imgSrc="/images/juri-lorenz-foto.webp"
  altText="Juri Lorenz – maxWapp Webentwicklung München"
  subtitle1="Kontakt"
title1="Erzähl kurz von deinem Projekt"
title2="und ich melde mich bei dir."
/>

<ContactFormCard />

<ContactDirectCard />

<LocationSection />

  </div>
</MainLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const msg = params.get("msg");

  if (msg) {
    const textarea = document.querySelector("textarea[name='message']");

    if (textarea instanceof HTMLTextAreaElement) {
      textarea.value = decodeURIComponent(msg);
      textarea.focus();
    }
  }
</script>