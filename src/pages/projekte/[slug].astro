const { slug } = Astro.params;
const { name, introText, seoTitle, seoDesc } = Astro.props;

---

<MainLayout title={name} seoTitle={seoTitle} seoDesc={seoDesc}>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "name": name,
    "description": seoDesc,
    "url": `https://maxwapp.de/projekte/${slug}`,
    "image": `https://maxwapp.de/images/projects/${slug}.webp`,
    "author": {
      "@type": "Person",
      "name": "Juri Lorenz"
    },
    "publisher": {
      "@type": "Organization",
      "name": "maxWapp",
      "url": "https://maxwapp.de"
    }
  })} />
  <div class="min-h-screen text-white">
    <h1 class="text-center text-4xl md:text-6xl font-bold drop-shadow-lg mt-12 md:mt-36 mb-8 mx-2">
      {name}
    </h1>

    <p class="text-center text-lg px-4 md:text-2xl text-gray-300 mb-12 max-w-4xl mx-auto">
      {introText}
    </p>

    <section class="mx-auto w-11/12 md:w-8/12 lg:w-6/12 flex flex-col items-center">
      <img 
        src={`/images/projects/${slug}.webp`}  
        class="rounded shadow-md drop-shadow-[0px_-35px_35px_rgba(75,0,130,0.6)] object-contain w-full h-auto max-h-[90vh]"
        alt={`Project ${name}`}
      />
    </section>

    <section class="my-12 w-10/12 md:w-8/12 lg:w-7/12 mx-auto">
      {slug === 'maa-art' && <MaaArt />}
      {slug === 'room-planetarium' && <RoomContent />}
      {slug === 'battle-calculator' && <BattleContent />}
