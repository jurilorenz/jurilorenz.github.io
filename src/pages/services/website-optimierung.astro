---
import MainLayout from "../../layouts/MainLayout.astro"
import IpadComponent from "../../components/IpadComponent.astro"

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Website-Optimierung",
    image: "https://maxwapp.de/images/maxwapp-website-optimierung.webp",
    description:
      "Optimierung bestehender Websites mit Fokus auf SEO, Geschwindigkeit, Conversion und Technik.",
    brand: {
      "@type": "Brand",
      name: "maxWapp",
    },
    offers: {
      "@type": "Offer",
      priceCurrency: "EUR",
      price: "900",
      availability: "http://schema.org/InStock",
      url: "https://maxwapp.de/website-optimieren-muenchen/",
    },
  },
]
---

<MainLayout
  title="Website optimieren München – Redesign & Relaunch | maxWapp"
  seoTitle="Website optimieren München – Redesign & Relaunch | maxWapp"
  seoDesc="Relaunch oder Redesign? Ich optimiere Ihre Website für Google: schneller, SEO-stärker, barrierefrei & conversion-orientiert. München-fokussiert."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- Hintergrund mit Verlauf -->
  <div
    class="min-h-screen bg-gradient-to-b from-[#090a1a] to-[#290065] text-white text-center flex flex-col items-center justify-center"
  >
    <!-- Titel -->
    <h1
      class="text-center text-3xl md:text-6xl font-bold text-gray-100 drop-shadow-lg mt-12 md:mb-12 md:mt-36"
    >
      Website optimieren in München – Redesign & Relaunch
    </h1>

    <!-- Hidden SEO Zusatzblock -->
    <p class="sr-only">
      ich unterstütze dich beim Relaunch einer Website, Relaunch Betreuung oder
      beim vollständigen Website Redesign. Ich helfe dir, deine Website für
      Suchmaschinen zu optimieren. Egal ob du deine Website für Google oder
      andere Suchmaschinen optimieren möchtest –
    </p>

    <!-- Inhalt Abschnitt -->
    <div
      class="w-11/12 md:w-10/12 lg:w-8/12 mx-auto text-lg md:text-xl text-gray-300 leading-relaxed mt-12 flex flex-col-reverse md:flex-row items-center gap-16 md:gap-32"
    >
      <!-- Handybildabschnitt für Desktop links -->
      <div
        class="w-full md:w-5/12 flex justify-center md:justify-end mb-12 md:mb-0 rounded shadow-md drop-shadow-[-35px_0px_35px_rgba(75,0,130,0.6)] phone-container"
      >
        <img
          src="/images/maxwapp-website-optimierung.webp"
          alt="Shopify Screenshot"
          class="w-80 md:w-auto md:max-h-[60vh] object-contain rounded-lg"
        />
      </div>

      <!-- Textabschnitt für Desktop rechts -->
      <div class="w-full md:w-5/12 text-center md:text-left">
        <p class="text-xl md:text-2xl mt-4">
          Deine Website braucht ein <strong>Redesign</strong>, einen <strong
            >Relaunch</strong
          > oder einfach ein gezieltes <strong>Optimieren</strong>? Ich finde
          die Schwachstellen – und optimiere sie gezielt.
        </p>

        <p class="text-xl md:text-2xl mt-8">
          Ob <strong>technisches Feintuning</strong>, <strong
            >Conversion-Optimierung</strong
          > oder <strong>SEO-Boost</strong> – schon kleine Anpassungen können <span
            class="text-gradient font-semibold">große Wirkung</span
          > zeigen. Du entscheidest, wie tief wir einsteigen.
        </p>

        <p class="text-xl md:text-2xl mt-8">
          Start mit <strong>kostenloser Ersteinschätzung</strong>: Audit von
          Core Web Vitals, Informationsarchitektur und Inhalten. Danach erhältst
          du einen klaren Maßnahmenplan.
        </p>
      </div>
    </div>

    <!-- Was ich biete Abschnitt mit Karten -->
    <h2 class="text-center text-4xl md:text-5xl font-extrabold my-24">
      Was ich biete
    </h2>

    <div
      class="grid grid-cols-1 md:grid-cols-2 gap-12 px-6 md:px-0 max-w-6xl mx-auto"
    >
      <!-- Karte 1: Shop-Redesign mit Conversion-Fokus -->
      <div
        class="relative bg-[#1b1b33] p-8 rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)]"
      >
        <div
          class="absolute top-0 left-0 bg-gradient-to-r from-purple-400 to-blue-500 w-full h-2 rounded-t-xl"
        >
        </div>
        <h4 class="text-3xl font-bold text-white mb-6">
          Conversion-Optimierung
        </h4>
        <p class="text-lg text-gray-300 leading-relaxed">
          Deine Seite wird besucht, aber es passiert nichts? Ich optimiere <strong
            >Struktur, Design & Calls-to-Action</strong
          >, damit Besucher auch wirklich Kunden werden.
        </p>
      </div>

      <!-- Karte 2: Shopify Setup & Startklar-Paket -->
      <div
        class="relative bg-[#1b1b33] p-8 rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)]"
      >
        <div
          class="absolute top-0 left-0 bg-gradient-to-r from-purple-400 to-blue-500 w-full h-2 rounded-t-xl"
        >
        </div>
        <h4 class="text-3xl font-bold text-white mb-6">Pagespeed & Technik</h4>
        <p class="text-lg text-gray-300 leading-relaxed">
          Ich beschleunige deine Website und sorge für sauberen Code – <strong
            >schneller Laden = bessere Rankings + bessere UX</strong
          >. Auch Google liebt Performance.
        </p>
      </div>

      <!-- Karte 3: Mobile-First & Conversion-Ready -->
      <div
        class="relative bg-[#1b1b33] p-8 rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)]"
      >
        <div
          class="absolute top-0 left-0 bg-gradient-to-r from-purple-400 to-blue-500 w-full h-2 rounded-t-xl"
        >
        </div>
        <h4 class="text-3xl font-bold text-white mb-6">Mobile-Optimierung</h4>
        <p class="text-lg text-gray-300 leading-relaxed">
          Ohne mobile Optimierung keine Sichtbarkeit: Ich mache deine Website <strong
            >mobilfreundlich, schnell & responsive</strong
          > – perfekt für Smartphone & Tablet.
        </p>
      </div>

      <!-- Karte 4: Barrierefreies Webdesign -->
      <div
        class="relative bg-[#1b1b33] p-8 rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)]"
      >
        <div
          class="absolute top-0 left-0 bg-gradient-to-r from-purple-400 to-blue-500 w-full h-2 rounded-t-xl"
        >
        </div>
        <h4 class="text-3xl font-bold text-white mb-6">
          Barrierefreies Webdesign
        </h4>
        <p class="text-lg text-gray-300 leading-relaxed">
          Ich sorge dafür, dass deine Website <strong
            >auch für Menschen mit Einschränkungen zugänglich</strong
          > ist – inklusive klarer Strukturen, guter Lesbarkeit und technischer Standards.
        </p>
      </div>
    </div>

    <h2
      class="text-center text-3xl md:text-4xl font-extrabold mt-36 mb-12 mx-2"
      style="line-height: 1.3;"
    >
      Kleine Änderungen – große Wirkung
    </h2>

    <p class="text-xl md:text-2xl text-gray-300 text-center max-w-4xl mx-2">
      Schon <strong>kleine Optimierungen</strong> können zu mehr Sichtbarkeit, Anfragen
      und <span class="underline-animation">Umsatz</span> führen. Ich analysiere
      deine Seite
      <span class="text-gradient font-semibold">kostenfrei</span> und setze gezielte
      Verbesserungen um.
    </p>
    <p
      class="text-xl md:text-2xl text-gray-300 text-center max-w-4xl mx-2 mt-6"
    >
      Du planst einen <strong>Relaunch der Website</strong> oder willst deine bestehende
      Seite <strong>für Google optimieren</strong>? Ich helfe dir dabei,
      strukturiert und messbar.
    </p>

    <!-- Relaunch-Prozess als Karten (B2C-freundlich) -->
    <h2
      class="text-center text-3xl md:text-4xl font-extrabold mt-36 mb-12 mx-2"
      style="line-height:1.3;"
    >
      Relaunch einer Website – so einfach geht’s
    </h2>

    <div
      class="grid grid-cols-1 md:grid-cols-2 gap-12 px-6 md:px-0 max-w-6xl mx-auto"
    >
      <!-- Karte 1 -->
      <div
        class="relative bg-[#1b1b33] p-8 rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)]"
      >
        <div
          class="absolute top-0 left-0 bg-gradient-to-r from-purple-400 to-blue-500 w-full h-2 rounded-t-xl"
        >
        </div>
        <h4 class="text-2xl md:text-3xl font-bold text-white mb-4">
          <span class="text-gradient">1.</span> Kurz-Check
        </h4>
        <p class="text-lg text-gray-300 leading-relaxed">
          Wir prüfen, was bremst: Ladezeit, Navigation, Handy-Ansicht und wie
          gut die Seite bei Google gefunden wird.
        </p>
      </div>

      <!-- Karte 2 -->
      <div
        class="relative bg-[#1b1b33] p-8 rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)]"
      >
        <div
          class="absolute top-0 left-0 bg-gradient-to-r from-purple-400 to-blue-500 w-full h-2 rounded-t-xl"
        >
        </div>
        <h4 class="text-2xl md:text-3xl font-bold text-white mb-4">
          <span class="text-gradient">2.</span> Mini-Plan
        </h4>
        <p class="text-lg text-gray-300 leading-relaxed">
          Struktur & Inhalte ordnen (Menüs, Texte, Bilder). Was bleibt, was
          kommt neu. Falls nötig: einfache Weiterleitungen, damit Google nichts
          verliert.
        </p>
      </div>

      <!-- Karte 3 -->
      <div
        class="relative bg-[#1b1b33] p-8 rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)]"
      >
        <div
          class="absolute top-0 left-0 bg-gradient-to-r from-purple-400 to-blue-500 w-full h-2 rounded-t-xl"
        >
        </div>
        <h4 class="text-2xl md:text-3xl font-bold text-white mb-4">
          <span class="text-gradient">3.</span> Umsetzung
        </h4>
        <p class="text-lg text-gray-300 leading-relaxed">
          Frisches Design (<strong>Website-Redesign</strong>), klare Texte,
          komprimierte Bilder, schnelle Technik. Kurz: <strong
            >Website optimieren</strong
          >, damit mehr Anfragen kommen – auch auf dem Smartphone.
        </p>
      </div>

      <!-- Karte 4 -->
      <div
        class="relative bg-[#1b1b33] p-8 rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)]"
      >
        <div
          class="absolute top-0 left-0 bg-gradient-to-r from-purple-400 to-blue-500 w-full h-2 rounded-t-xl"
        >
        </div>
        <h4 class="text-2xl md:text-3xl font-bold text-white mb-4">
          <span class="text-gradient">4.</span> Start & Feinschliff
        </h4>
        <p class="text-lg text-gray-300 leading-relaxed">
          Live schalten, Kontakt/Termin testen, Indexierung bei Google prüfen
          und kleine Korrekturen. Fertig.
        </p>
      </div>
    </div>

    <!-- CTA-Karte (ohne Preise) -->
    <div class="max-w-6xl mx-auto px-6 md:px-0 mt-8">
      <div
        class="relative bg-[#13132a] p-6 md:p-8 rounded-xl border border-gray-700 text-center shadow-[0px_0px_35px_rgba(147,112,219,0.35)]"
      >
        <div
          class="absolute top-0 left-0 bg-gradient-to-r from-purple-400 to-blue-500 w-full h-1 rounded-t-xl"
        >
        </div>
        <p class="text-base md:text-lg text-gray-200">
          Starte mit einer <a
            href="/kontakt"
            class="underline underline-offset-4 decoration-2"
            >kostenlosen Potenzialanalyse</a
          > – 10–15 schnelle Ideen für deinen <strong>Website-Relaunch</strong> und
          um die
          <strong>Website für Google zu optimieren</strong>.
        </p>
      </div>
    </div>

    <IpadComponent
      imgSrc="/images/ipad-pagespeed-test-maxwapp.webp"
      imgAlt="Screenshot: Google PageSpeed Insights – Ergebnis für maxWapp"
    />

    <!-- FAQ (карточки тем же стилем) -->
    <h2
      class="text-center text-4xl md:text-5xl font-extrabold md:mt-24 mt-12 mb-24"
    >
      Häufige Fragen zu Redesign, Relaunch & Optimierung
    </h2>
    <div
      class="grid grid-cols-1 md:grid-cols-2 gap-12 px-6 md:px-0 max-w-6xl mx-auto"
    >
      <div
        class="relative bg-[#1b1b33] p-8 rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)]"
      >
        <div
          class="absolute top-0 left-0 bg-gradient-to-r from-purple-400 to-blue-500 w-full h-2 rounded-t-xl"
        >
        </div>
        <h4 class="text-3xl font-bold text-white mb-6">
          Wie optimiere ich meine Website für Google?
        </h4>
        <p class="text-lg text-gray-300 leading-relaxed">
          Technik + Content + interne Verlinkung. Ich starte mit Audit &
          Quick-Wins.
        </p>
      </div>

      <div
        class="relative bg-[#1b1b33] p-8 rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)]"
      >
        <div
          class="absolute top-0 left-0 bg-gradient-to-r from-purple-400 to-blue-500 w-full h-2 rounded-t-xl"
        >
        </div>
        <h4 class="text-3xl font-bold text-white mb-6">
          Website Redesign vs. Relaunch – was ist besser?
        </h4>
        <p class="text-lg text-gray-300 leading-relaxed">
          Redesign = UX/UI. Relaunch = plus Technik, Struktur & SEO-Migration.
          Entscheide nach Zielen.
        </p>
      </div>

      <div
        class="relative bg-[#1b1b33] p-8 rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)]"
      >
        <div
          class="absolute top-0 left-0 bg-gradient-to-r from-purple-400 to-blue-500 w-full h-2 rounded-t-xl"
        >
        </div>
        <h4 class="text-3xl font-bold text-white mb-6">
          Website optimieren lassen – was passiert zuerst?
        </h4>
        <p class="text-lg text-gray-300 leading-relaxed">
          Kostenlose Ersteinschätzung, dann Prioritäten-Plan mit Maßnahmen &
          Zeitleiste.
        </p>
      </div>

      <div
        class="relative bg-[#1b1b33] p-8 rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)]"
      >
        <div
          class="absolute top-0 left-0 bg-gradient-to-r from-purple-400 to-blue-500 w-full h-2 rounded-t-xl"
        >
        </div>
        <h4 class="text-3xl font-bold text-white mb-6">
          Barrierefreies Webdesign – warum wichtig?
        </h4>
        <p class="text-lg text-gray-300 leading-relaxed">
          Mehr Nutzer, bessere Usability, oft bessere SEO-Signale. Ich plane das
          von Anfang an ein.
        </p>
      </div>
    </div>

    <!-- Warum mit mir arbeiten Abschnitt -->
    <h2
      class="text-center text-4xl md:text-5xl font-extrabold mt-36 mb-12 md:mb-24 mx-2"
      style="line-height: 1.3;"
    >
      Analyse, Strategie, Umsetzung.
    </h2>

    <div
      class="w-11/12 md:w-10/12 lg:w-8/12 mx-auto flex flex-col md:flex-row items-center mb-24 md:gap-24"
    >
      <!-- Handybildabschnitt für Desktop links -->
      <div
        class="w-full md:w-5/12 flex justify-center md:justify-center mb-12 md:mb-0 rounded shadow-md drop-shadow-[-35px_0px_35px_rgba(75,0,130,0.6)] phone-container-second"
      >
        <img
          src="/images/maxwapp-iphone-2.webp"
          alt="Shopify Screenshot Kollektion"
          class="w-80 md:w-auto md:max-h-[60vh] object-contain rounded-lg"
        />
      </div>

      <!-- Textabschnitt für Desktop rechts -->
      <div class="w-full md:w-5/12 text-center md:text-left">
        <p class="text-xl md:text-2xl mt-4">
          Viele Agenturen sehen nur das Design. Ich schaue auf das, was wirklich
          zählt: <span class="text-gradient">Zielgruppen, Verhalten, Daten</span
          > – und mache daraus eine Website, die wirkt.
        </p>

        <p class="text-xl md:text-2xl mt-8">
          Wenn du eine erfahrene <strong>Website Relaunch Agentur</strong> suchst
          – ich unterstütze dich persönlich und direkt.
        </p>

        <p class="text-xl md:text-2xl mt-8">
          Starte jetzt mit einer kostenlosen<span class="underline-animation"
            >Potenzialanalyse</span
          >!
        </p>

        <!-- Buttons at the bottom-right -->
        <div
          class="flex flex-col md:flex-row gap-6 mt-8 md:mt-16 justify-center md:justify-start items-center md:items-start w-full md:w-auto"
        >
          <!-- Primary Button -->
          <a
            href="/kontakt"
            class="relative inline-block py-4 px-10 rounded-full font-bold text-center w-full max-w-xs md:max-w-none md:w-auto bg-white text-[#090a1a] shadow-lg transition-all duration-300 ease-in-out hover:shadow-[0_0_20px_rgba(147,112,219,0.8),_0_0_35px_rgba(3,169,244,0.6)] hover:border-[#6d87d1]"
          >
            Gratis Analyse
          </a>
        </div>
      </div>

      <style>
        .text-gradient {
          background: linear-gradient(to right, #9c27b0, #03a9f4);
          -webkit-background-clip: text;
          color: transparent;
        }

        .drop-shadow-lg {
          filter: drop-shadow(0 8px 16px rgba(0, 0, 0, 0.2));
        }

        .border-gradient-to-r {
          border-image-slice: 1;
          border-image-source: linear-gradient(to right, #9c27b0, #03a9f4);
        }

        /* Container for the entire image, gradient, and shadow */
        .profile-container {
          transform: translateX(-150%); /* Start off-screen to the left */
          opacity: 0; /* Initially hidden */
          transition:
            transform 1.5s ease-out,
            opacity 1.5s ease-out;
        }

        /* Trigger the animation when the page loads */
        .profile-container {
          animation: flyInFromLeft 1.5s forwards;
        }

        /* Keyframes for the fly-in effect */
        @keyframes flyInFromLeft {
          0% {
            transform: translateX(-150%);
            opacity: 0;
          }
          100% {
            transform: translateX(0);
            opacity: 1;
          }
        }

        /* Container for the entire image and shadow */
        .phone-container {
          transform: translateX(-150%); /* Start off-screen to the left */
          opacity: 0; /* Initially hidden */
          transition:
            transform 1.5s ease-out,
            opacity 1.5s ease-out; /* Remove delay for mobile */
        }

        /* Fly in effect */
        .fly-in {
          transform: translateX(0);
          opacity: 1;
        }

        /* Keyframes for desktop (initial load) */
        @media (min-width: 768px) {
          .phone-container {
            animation: flyInFromLeftPhone 1.5s forwards 0.5s; /* Keep delay on desktop */
          }

          .underline-animation {
            display: inline-block;
            background-image: linear-gradient(120deg, #03a9f4, #9c27b0);
            background-repeat: no-repeat;
            background-size: 100% 3px;
            background-position: 0 88%;
            transition: background-size 0.3s ease-in-out;
          }

          .underline-animation:hover {
            background-size: 100% 100%;
          }
        }

        /* Keyframes for mobile (on scroll) */
        @keyframes flyInFromLeftPhone {
          0% {
            transform: translateX(-150%);
            opacity: 0;
          }
          100% {
            transform: translateX(0);
            opacity: 1;
          }
        }

        /* Initial state for the second phone container */
        .phone-container-second {
          transform: translateX(-150%); /* Positioned off-screen to the left */
          opacity: 0; /* Initially hidden */
          transition:
            transform 1.5s ease-out,
            opacity 1.5s ease-out;
        }

        /* Fly-in effect when in view */
        .fly-in-second {
          transform: translateX(0); /* Return to original position */
          opacity: 1; /* Fully visible */
        }
      </style>

      <script>
        document.addEventListener("DOMContentLoaded", function () {
          const phoneImage = document.querySelector(".phone-container")

          // Detect if the element is in view for mobile
          function isInViewPort(element) {
            const rect = element.getBoundingClientRect()
            return (
              rect.top <=
                (window.innerHeight || document.documentElement.clientHeight) &&
              rect.bottom >= 0
            )
          }

          // Add event listener for scroll to trigger the animation
          window.addEventListener("scroll", function () {
            if (window.innerWidth < 768) {
              // Only apply for mobile view
              if (isInViewPort(phoneImage)) {
                phoneImage.classList.add("fly-in")
              }
            }
          })
        })

        document.addEventListener("DOMContentLoaded", function () {
          const secondPhoneImage = document.querySelector(
            ".phone-container-second",
          )

          // Function to check if the element is in the viewport
          function isInViewPort(element) {
            const rect = element.getBoundingClientRect()
            return (
              rect.top <=
                (window.innerHeight || document.documentElement.clientHeight) &&
              rect.bottom >= 0
            )
          }

          // Function to add the fly-in class when in view
          function handleScroll() {
            if (isInViewPort(secondPhoneImage)) {
              secondPhoneImage.classList.add("fly-in-second")
            }
          }

          // Add scroll event listener
          window.addEventListener("scroll", handleScroll)

          // Run on page load in case the element is already in view
          handleScroll()
        })
      </script>
    </div>
  </div>
</MainLayout>
