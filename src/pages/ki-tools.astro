      </div>
    </div>



    
    <!-- Sichtbarer Infoblock zu Integrationen -->
    <h2
      class="text-center text-3xl md:text-4xl font-extrabold mt-36 mb-12"
      style="line-height: 1.3;"
    >
      Beliebte Integrationen für deine Website
    </h2>

    <ul
      class="text-xl md:text-2xl text-gray-300 max-w-3xl mx-4 list-disc pl-6 space-y-3 text-left leading-relaxed"
    >
      <li><strong>Terminbuchung:</strong> Planity, Shore, Calendly</li>
