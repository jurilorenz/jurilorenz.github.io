---
import MainLayout from "../layouts/MainLayout.astro"
import SolutionSection from "../components/SolutionSection.astro";
import FeatureGridSection from "../components/FeatureGridSection.astro";
import MotionSection from "../components/MotionSection.astro";
import ImageBanner from "../components/ImageBanner.astro";
import FinalCTASection from "../components/FinalCTASection.astro";

const features = [
  { title: "Klare Prozesse", description: "Planity Termin, Calendly Buchung & OnOffice Daten sind logisch eingebunden – ohne Chaos." },
  { title: "Saubere Integration", description: "Tools, APIs und Formulare arbeiten zusammen – stabil, wartbar und verständlich übergeben." },
  { title: "Automatisierung", description: "Weniger Nachfassen: Bestätigungen, Erinnerungen und smarte Abläufe laufen automatisch." },
  { title: "Mehr Anfragen", description: "Bessere Nutzerführung + klare CTAs = mehr Leads, die wirklich passen." },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "KI & Tools Integration",
  image:
    "https://maxwapp.de/images/projects/immobilien-muenchen-referenzobjekte.webp",
  description:
    "Ich integriere Tools, APIs und KI-Lösungen wie OnOffice, Planity & OpenAI direkt in deine Website – automatisiert und zukunftssicher.",
  brand: {
    "@type": "Brand",
    name: "maxWapp",
  },
  offers: {
    "@type": "Offer",
    priceCurrency: "EUR",
    price: "900",
    availability: "https://schema.org/InStock",
    url: "https://maxwapp.de/preise",
  },
}
---

<MainLayout
  title="KI & Tools Integration aus München – automatisiert, smart & leistungsstark | maxWapp"
