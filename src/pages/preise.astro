<style>
/* ROI-Highlight: Investment -> Ergebnis */
.roi-highlight {
  margin: 2.5rem auto 2rem;
  max-width: 48rem;
  text-align: center;
}

.roi-pill {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.9rem 1.6rem;
  border-radius: 9999px;
  background: linear-gradient(120deg, #9c27b0, #03a9f4, #9c27b0);
  background-size: 200% 200%;
  animation: roiGradient 6s ease infinite;
  box-shadow: 0 0 18px rgba(147, 112, 219, 0.6);
}

.roi-pill-small {
  font-size: 0.85rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: rgba(255, 255, 255, 0.85);
}

.roi-pill-big {
  font-size: 1.05rem;
  font-weight: 700;
  color: #ffffff;
}

.roi-pill-arrow {
  font-size: 1.2rem;
  color: #ffe082;
  animation: roiArrow 1.8s ease-in-out infinite;
}

.roi-text {
  margin-top: 0.75rem;
  font-size: 1.1rem;
  color: #e5e5f5;
}

/* Desktop-Feinschliff */
@media (min-width: 768px) {
  .roi-pill-big {
    font-size: 1.15rem;
  }
  .roi-text {
    font-size: 1.25rem;
  }
}

/* Animierter Farbverlauf */
@keyframes roiGradient {
  0% {
    background-position: 0% 50%;
  }
  50% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0% 50%;
  }
}

/* Leichte Pfeilbewegung (Investition -> Ergebnis) */
@keyframes roiArrow {
  0%,
  100% {
    transform: translateX(0);
  }
  50% {
    transform: translateX(4px);
  }
}
</style>