---
import MainLayout from "../layouts/MainLayout.astro"
import PriceCalculator from "../components/PriceCalculator.astro"
import BulletSplitSection from "../components/BulletSplitSection.astro"
import FeatureGridSection from "../components/FeatureGridSection.astro"
import FinalCTASection from "../components/FinalCTASection.astro"
import RoiHighlight from "../components/RoiHighlight.astro"
import ImageBanner from "../components/ImageBanner.astro"
import SolutionSection from "../components/SolutionSection.astro"
import PrimaryHeroSection from "../components/PrimaryHeroSection.astro"

const includedFeatures = [
  {
    title: "Konzept & Design",
    description: "Struktur, Designrichtung und ein klarer Aufbau für dein Angebot – damit Besucher sofort verstehen, worum es geht.",
  },
  {
    title: "Technische Einrichtung",
    description: "Sauberes Setup, Basis-Konfiguration und eine stabile technische Grundlage für deine Website.",
  },
  {
    title: "Mobil optimiert",
    description: "Deine Website funktioniert sauber auf Smartphone, Tablet und Desktop – ohne Frust für Besucher.",
  },
  {
    title: "Kontaktformular & DSGVO-Basis",
    description: "Kontaktmöglichkeit, Impressum und Datenschutz-Basis sind direkt sauber mitgedacht.",
  },
]

const priceFactors = [
  {
    title: "Seitenanzahl & Umfang",
    description: "Je mehr Unterseiten deine Website braucht, desto höher ist der Aufwand für Struktur, Inhalte und Gestaltung.",
  },
  {
    title: "SEO & Google-Sichtbarkeit",
    description: "SEO-optimierte Seiten, Keyword-Recherche und technische Vorbereitung für Google beeinflussen den Preis direkt.",
  },
  {
    title: "Funktionen & Erweiterungen",
    description: "Kalender, Mehrsprachigkeit, Shop oder ein Google Maps Profil erhöhen Umfang und Umsetzungszeit.",
  },
  {
    title: "Shop & Produkte",
    description: "Wenn ein Online-Shop integriert wird, spielen auch Produktanzahl und Zahlungsarten eine wichtige Rolle.",
  },
]

const processSteps = [
  {
    title: "1. Konfiguration im Kalkulator",
    description: "Du stellst dir eine erste Kombination aus Seiten, SEO und Funktionen zusammen und bekommst sofort einen Richtwert.",
  },
  {
    title: "2. Kurze Anfrage",
    description: "Danach besprechen wir dein Projekt, Ziele und Umfang – unverbindlich und ohne komplizierten Prozess.",
  },
  {
    title: "3. Konkretes Angebot",
    description: "Auf Basis deiner Anforderungen bekommst du ein klares Angebot statt einer unübersichtlichen Preisliste.",
  },
  {
    title: "4. Umsetzung mit Plan",
    description: "Nach Freigabe setze ich deine Website strukturiert um – mit Fokus auf Performance, Sichtbarkeit und Anfragen.",
  },
]

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Website erstellen lassen – Kosten & Preise",
  "provider": { "@type": "Brand", "name": "maxWapp" },
  "areaServed": "DE",
  "offers": {
    "@type": "Offer",
    "priceCurrency": "EUR",
    "price": "1500",
    "availability": "https://schema.org/InStock",
    "url": "https://maxwapp.de/preise"
  }
}
---

<MainLayout
  title="Website erstellen lassen – Kosten & Preise | maxWapp"
  seoTitle="Website erstellen lassen Preise – Kosten & Preisrechner"
  seoDesc="Website erstellen lassen Preise im Überblick. Was kostet eine professionelle Website? Klare Kosten, Beispiele und Preisrechner für dein Projekt."
>
<p class="sr-only">
Website erstellen lassen – Preise, Kosten und Orientierung mit Preisrechner für dein Projekt.
</p>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <div
    class="min-h-screen bg-gradient-to-b from-[#090a1a] to-[#290065] text-white text-center flex flex-col items-center justify-center scroll-smooth"
  >

<PrimaryHeroSection
  title="Website erstellen lassen Preise"
  lead="Was kostet eine professionelle Website? Hier bekommst du einen klaren Preisrahmen, direkte Orientierung und einen Website Preisrechner für dein Projekt."
  leadMobile="Website Preise im Überblick – mit Preisrechner und klarer Orientierung."
  desktopImgSrc="/images/website-erstellen-preise-illustration.webp"
  mobileImgSrc="/images/website-erstellen-preise-illustration.webp"
  imgAlt="Website erstellen lassen Preise – Webdesign und Kalkulation in München"
  ctaLabel="Preise berechnen"
  ctaHref="#preisrechner"
/>

    <PriceCalculator />

    <BulletSplitSection
      title="Wie Website-Preise entstehen"
      imgSrc="/images/projects/battle-calculator.webp"
      imgAlt="Illustration zur Preisstruktur einer Website"
      showHighlight={false}
      imageFirstOnMobile={true}
      items={[
        "Seitenanzahl und Inhaltsumfang",
        "SEO-optimierte Seiten und Google-Vorbereitung",
        "Technischer Aufwand & Erweiterungen",
      ]}
extraText={`Der Kalkulator zeigt dir einen ersten Richtwert, wenn du eine <strong><a href="/landingpage-erstellen-lassen/" class="underline underline-offset-4">Landingpage</a></strong> oder eine <strong><a href="/wordpress-website-erstellen-lassen/" class="underline underline-offset-4">Website</a></strong> erstellen lassen möchtest. Die tatsächlichen <strong>Kosten</strong> hängen von Struktur, Funktionen und Zielen deines Projekts ab.`} extraTextPosition="after"
    />

    <FeatureGridSection
      title="Was im Startpaket enthalten ist"
      intro="Schon das Startpaket deckt die wichtigsten Bausteine ab, damit deine Website professionell wirkt und sauber aufgebaut ist."
      features={includedFeatures}
      cols={2}
afterText={`Damit bekommst du nicht einfach nur eine schöne Oberfläche, sondern eine funktionierende Grundlage für Sichtbarkeit, Vertrauen und Anfragen. Gerade wenn du eine <strong><a href="/wordpress-website-erstellen-lassen/" class="underline underline-offset-4">Homepage erstellen lassen</a></strong> möchtest, entscheidet diese Basis über den späteren Erfolg. Wenn bereits eine Seite existiert, kann auch ein <strong><a href="/website-relaunch-redesign/" class="underline underline-offset-4">Website-Relaunch</a></strong> sinnvoller sein.`}      ctaLabel="Projekt anfragen"
      ctaHref="/kontakt"
    />

    <ImageBanner
      imgSrc="/images/webdesigner-arbeitsplatz-maxwapp.webp"
      imgAlt="Arbeitsplatz mit zwei Monitoren – Symbol für klare Preisstruktur und effiziente Website-Umsetzung"
      eyebrow="Preis & Value"
      title="Klare Preise statt Agentur-Overhead"
text={`
  <p><strong>Du willst eine professionelle Website erstellen lassen</strong>, aber keine intransparenten Agenturpreise zahlen? Bei mir bekommst du eine direkte Zusammenarbeit, klare Kommunikation und eine Preisstruktur, die nachvollziehbar bleibt.</p>
  <p>Als <strong>Einzelunternehmer</strong> arbeite ich ohne unnötige Zwischenebenen. Das bedeutet: weniger Overhead, direkter Austausch und mehr Leistung dort, wo sie zählt – in Struktur, Design, Sichtbarkeit und Conversion. Je nach Projekt reicht eine <a href="/landingpage-erstellen-lassen/" class="underline underline-offset-4">Landingpage</a>, eine <a href="/wordpress-website-erstellen-lassen/" class="underline underline-offset-4">WordPress Website</a> oder ein <a href="/online-shop-erstellen-lassen/" class="underline underline-offset-4">Online-Shop</a>.</p>
`}
      ctaLabel="Projekt anfragen"
      ctaHref="/kontakt"
    />

    <BulletSplitSection
      title="Preis ist nicht entscheidend"
  imgSrc="/images/website-preis-investition-performance.webp"
      imgAlt="Illustration einer Website mit steigender Performance und Euro-Symbol – steht für Investition in eine professionelle Website mit messbarem Geschäftserfolg"
      showHighlight={false}
      imageFirstOnMobile={true}
      extraText={`Viele vergleichen zuerst Zahlen. Entscheidend ist aber, was eine Website
      für dein Business leistet: ob sie Vertrauen aufbaut, Anfragen bringt und
      dein Angebot klar verkauft.`}
      extraTextPosition="after"
    />

            <RoiHighlight
      text={`Eine <strong>professionelle Website</strong> kostet Geld – aber eine unklare, langsame oder schwache Website kostet oft mehr. Mit einer sauberen Struktur investierst du nicht in Deko, sondern in Vertrauen, Sichtbarkeit und planbare Anfragen.`}
      href="/kontakt"
      pillSmall="Heute investieren"
      pillBig="morgen mehr Anfragen &amp; Umsatz"
    />

    <FeatureGridSection
      title="Welche Faktoren den Preis deiner Website beeinflussen"
      intro="Wenn du wissen willst, was die Erstellung einer Homepage kostet, sind diese vier Punkte entscheidend."
      features={priceFactors}
      cols={2}
      afterText={`Die Frage <strong>„Was kostet eine professionelle Website?“</strong> lässt sich deshalb nie mit nur einer Zahl beantworten. Der Kalkulator hilft dir, typische Preisfaktoren sichtbar zu machen – statt mit unklaren Paketpreisen zu arbeiten.`}
      ctaLabel="Projekt anfragen"
      ctaHref="/kontakt"
    />

<SolutionSection
  title="Warum der Kalkulator mit Richtwerten arbeitet"
  intro="Du bekommst zuerst eine klare Orientierung – danach ein konkretes Angebot für dein Projekt."
  steps={[
    {
      num: "1",
      title: "Klare Orientierung",
      text: "Sofort verstehen, in welchem Rahmen sich dein Projekt bewegt.",
    },
    {
      num: "2",
      title: "Transparente Logik",
      text: "Preis entsteht durch Seiten, Funktionen und Struktur.",
    },
    {
      num: "3",
      title: "Individuell",
      text: "Kein Standard. Dein Angebot basiert auf deinem Projekt.",
    },
    {
      num: "4",
      title: "Direkt",
      text: "Ohne Agentur-Overhead. Klare Kommunikation, schnelle Umsetzung.",
    },
  ]}

/>

<FeatureGridSection
  title="So wird aus dem Richtwert ein konkretes Angebot"
  intro="Der Kalkulator ist der Einstieg. Danach wird dein Projekt sauber eingeordnet und konkret geplant."
  features={processSteps}
  cols={2}
afterText={`Du bekommst also keine unklare Preisidee, sondern einen nachvollziehbaren Weg von der ersten Orientierung bis zur fertigen Website. Wenn du dir ein Bild machen willst, schau dir meine <a href="/projekte/" class="underline underline-offset-4">Projekte</a> an.`}  ctaLabel="Projekt anfragen"
  ctaHref="/kontakt"
/>

    <FinalCTASection
      title="Du hast deine Website-Kosten kalkuliert?"
      description={`
        <p>Dann lass uns den nächsten Schritt gehen. Ich prüfe deine Anforderungen, gebe dir ehrliches Feedback und mache dir ein konkretes Angebot – transparent, direkt und ohne Agentur-Overhead.</p>
      `}
      ctaLabel="Projekt anfragen"
      ctaHref="/kontakt"
    />
  </div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const trigger = document.querySelector('a[href="#preisrechner"]');
    const target = document.getElementById("preisrechner");

    if (!(trigger instanceof HTMLAnchorElement) || !(target instanceof HTMLElement)) return;

    trigger.addEventListener("click", (e) => {
      e.preventDefault();
      target.scrollIntoView({ behavior: "smooth", block: "start" });
    });
  });
</script>
</MainLayout>
