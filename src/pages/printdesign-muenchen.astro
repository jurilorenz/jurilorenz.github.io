    </div>

 <!-- Was ich biete Abschnitt mit Karten -->
    <h2 class="text-center text-4xl md:text-5xl font-extrabold md:mt-24 mt-12 mb-24">
      Was ich biete
    </h2>

    <div
      class="grid grid-cols-1 md:grid-cols-2 gap-12 px-6 md:px-0 max-w-6xl mx-auto"
    >
      <!-- Karte 1: Schnelle Websites -->
