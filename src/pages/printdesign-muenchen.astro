          class="w-80 md:w-auto md:max-h-[60vh] object-contain rounded-lg"
        />
      </div>

      <!-- Textabschnitt für Desktop rechts -->
      <div class="w-full md:w-5/12 text-center md:text-left">
        <p class="text-xl md:text-2xl mt-0">
          Deine Marke ist mehr als nur ein Logo – sie ist das Gefühl, das du bei
          deiner Zielgruppe auslöst. Ich helfe dir, diese Wirkung bewusst zu
          gestalten.
        </p>

        <p class="text-xl md:text-2xl mt-8">
          Ob <strong>durchdachtes Branding</strong>, <strong
            >starkes visuelles Konzept</strong
          > oder <strong>professionelles Printdesign</strong> – ich mache deine
          Marke sichtbar, wiedererkennbar und vertrauenswürdig.
        </p>

        <p class="text-xl md:text-2xl mt-8">
          Vom Logo bis zur Visitenkarte bekommst du alles aus einer Hand – <span
            class="text-gradient font-semibold"
            >kreativ, stimmig & individuell auf dein Business abgestimmt</span
