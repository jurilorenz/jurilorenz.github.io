---
import MainLayout from "../layouts/MainLayout.astro"
import IpadComponent from "../components/IpadComponent.astro"


const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Printdesign & Branding aus München",
  "description": "Flyer erstellen & drucken, Visitenkarten Design (QR-Code), Corporate Design & Logo-Erstellung – alles aus einer Hand.",
  "provider": {
    "@type": "Organization",
    "name": "maxWapp",
    "url": "https://maxwapp.de"
  },
  "areaServed": {
    "@type": "City",
    "name": "München"
  },
  "offers": {
    "@type": "Offer",
    "priceCurrency": "EUR",
    "price": "100",
    "availability": "https://schema.org/InStock",
    "url": "https://maxwapp.de/printdesign-muenchen/"
  }
}
---

<MainLayout
  title="Printdesign München: Flyer, Visitenkarten & Logo Design"
  seoTitle="Printdesign München: Flyer, Visitenkarten & Logo Design"
  seoDesc="Printdesign in München: Flyer erstellen & drucken, Visitenkarten Design mit QR-Code und Logo erstellen lassen. Corporate Design für Unternehmen."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <!-- Hintergrund mit Verlauf -->
  <div
    class="min-h-screen bg-gradient-to-b from-[#090a1a] to-[#290065] text-white text-center flex flex-col items-center justify-center"
  >
    <!-- Titel -->
    <h1
      class="text-center text-3xl md:text-6xl font-bold text-gray-100 drop-shadow-lg mt-12 md:mb-12 md:mt-36"
    >
      Printdesign München – Flyer, Visitenkarten & Logo Design
    </h1>

<p class="sr-only">
  Printdesign & Branding in München: Flyer erstellen und drucken, Flyer Design,
  Visitenkarten Design und Visitenkarten mit QR-Code, digitale Visitenkarte erstellen,
  Logo erstellen lassen und Logo Redesign, Corporate Identity & Corporate Design.
</p>

<p class="max-w-3xl mx-2 text-lg md:text-2xl text-gray-300 mt-6">
  Alles für deinen Auftritt: <strong>Flyer erstellen &amp; drucken</strong>,
  Visitenkarten mit QR Code,
  <strong>Logo erstellen lassen</strong> und
  <span class="text-gradient font-semibold">Corporate Design</span>.
  Lokal in München, professionell umgesetzt – von der Idee bis zur
  <span class="underline-animation">Druckabnahme</span>.
</p>


    <div
      class="flex flex-col items-center md:flex-row md:justify-center md:items-center md:space-x-32 mt-12"
    >
      <!-- Profilbild mit Farbverlauf-Rahmen und Schatten -->
      <div
        class="rounded-full p-1 bg-gradient-to-r from-purple-400 to-blue-500 shadow-md drop-shadow-[-35px_0px_35px_rgba(75,0,130,0.6)] profile-container"
      >
        <div class="rounded-full bg-[#090a1a] p-0">
          <img
            src="/images/projects/streetly-logo.webp"
            class="rounded-full w-48 h-48 md:w-56 md:h-56 object-cover"
            alt="Branding und Logodesing für ein Start-up in München - maxWapp"
          />
        </div>
      </div>

      <!-- Motto-Text neben dem Bild -->
      <div class="text-center md:text-left md:pl-12 mt-6 md:mt-0">
        <p class="text-2xl md:text-2xl font-medium text-gray-300">
          <span>Logo</span><br />
          <span>Design </span><br />
        </p>

        <!-- Hauptmotto -->
        <p class="mt-4 text-5xl md:text-6xl font-extrabold">
          <span>Max</span><br />
          <span>Wapp</span>
        </p>
      </div>
    </div>

    <!-- Inhalt Abschnitt -->
    <div
      class="w-11/12 md:w-10/12 lg:w-8/12 mx-auto text-lg md:text-xl text-gray-300 leading-relaxed mt-20 md:mt-32 flex flex-col-reverse md:flex-row items-center gap-16 md:gap-32"
    >
      <!-- Handybildabschnitt für Desktop links -->
      <div
        class="w-full md:w-5/12 flex justify-center md:justify-end mb-12 md:mb-0 rounded shadow-md drop-shadow-[-35px_0px_35px_rgba(75,0,130,0.6)] phone-container"
      >
        <img
          src="/images/projects/pizzeria-mondo-menu-flyer.webp"
