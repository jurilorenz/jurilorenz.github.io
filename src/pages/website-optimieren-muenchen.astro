      <p class="text-lg text-gray-300 leading-relaxed">Speed- und Conversion-Änderungen wirken oft sofort. SEO braucht je nach Ausgangslage Wochen – wichtig ist ein sauberer Maßnahmenplan.</p>
    </div>
  </div>

    <!-- Warum mit mir arbeiten Abschnitt -->
    <h2
      class="text-center text-4xl md:text-5xl font-extrabold mt-36 mb-12 md:mb-24 mx-2"
      style="line-height: 1.3;"
    >
      Analyse, Strategie, Umsetzung.
    </h2>

    <div
      class="w-11/12 md:w-10/12 lg:w-8/12 mx-auto flex flex-col md:flex-row items-center mb-24 md:gap-24"
    >
      <!-- Handybildabschnitt für Desktop links -->
      <div
        class="w-full md:w-5/12 flex justify-center md:justify-center mb-12 md:mb-0 rounded shadow-md drop-shadow-[-35px_0px_35px_rgba(75,0,130,0.6)] phone-container-second"
      >
        <img
          src="/images/maxwapp-iphone-2.webp"
          alt="Website-Optimierung Beispielansicht auf dem Smartphone (maxWapp)"
          class="w-80 md:w-auto md:max-h-[60vh] object-contain rounded-lg"
        />
      </div>

      <!-- Textabschnitt für Desktop rechts -->
      <div class="w-full md:w-5/12 text-center md:text-left">
        <p class="text-xl md:text-2xl mt-4">
          Viele Agenturen sehen nur das Design. Ich schaue auf das, was wirklich
          zählt: <span class="text-gradient">Zielgruppen, Verhalten, Daten</span
          > – und mache daraus eine Website, die wirkt.
        </p>

        <p class="text-xl md:text-2xl mt-8">
          Wenn du eine Website willst, die schneller lädt, besser gefunden wird und mehr Anfragen bringt,
          unterstütze ich dich persönlich – mit Audit, Prioritäten und sauberer Umsetzung.
        </p>

        <p class="text-xl md:text-2xl mt-8">
          Starte jetzt mit einer kostenlosen <span class="underline-animation">Potenzialanalyse</span>.
        </p>

        <!-- Buttons at the bottom-right -->
        <div
          class="flex flex-col md:flex-row gap-6 mt-8 md:mt-16 justify-center md:justify-start items-center md:items-start w-full md:w-auto"
        >


          <!-- Primary Button -->
          <a
            href="/kontakt"
            class="relative inline-block py-4 px-10 rounded-full font-bold text-center w-full max-w-xs md:max-w-none md:w-auto bg-white text-[#090a1a] shadow-lg transition-all duration-300 ease-in-out hover:shadow-[0_0_20px_rgba(147,112,219,0.8),_0_0_35px_rgba(3,169,244,0.6)] hover:border-[#6d87d1]"
          >
            Gratis Analyse
          </a>
        </div>
      </div>

      <style>
        .text-gradient {
          background: linear-gradient(to right, #9c27b0, #03a9f4);
          -webkit-background-clip: text;
          color: transparent;
        }

        .drop-shadow-lg {
          filter: drop-shadow(0 8px 16px rgba(0, 0, 0, 0.2));
        }

        .border-gradient-to-r {
          border-image-slice: 1;
          border-image-source: linear-gradient(to right, #9c27b0, #03a9f4);
        }

        /* Container for the entire image, gradient, and shadow */
        .profile-container {
          transform: translateX(-150%); /* Start off-screen to the left */
          opacity: 0; /* Initially hidden */
          transition:
            transform 1.5s ease-out,
            opacity 1.5s ease-out;
        }

        /* Trigger the animation when the page loads */
        .profile-container {
          animation: flyInFromLeft 1.5s forwards;
        }

        /* Keyframes for the fly-in effect */
        @keyframes flyInFromLeft {
          0% {
            transform: translateX(-150%);
            opacity: 0;
          }
          100% {
            transform: translateX(0);
            opacity: 1;
          }
        }

        /* Container for the entire image and shadow */
        .phone-container {
          transform: translateX(-150%); /* Start off-screen to the left */
          opacity: 0; /* Initially hidden */
          transition:
            transform 1.5s ease-out,
            opacity 1.5s ease-out; /* Remove delay for mobile */
        }

        /* Fly in effect */
        .fly-in {
          transform: translateX(0);
          opacity: 1;
        }

        /* Keyframes for desktop (initial load) */
        @media (min-width: 768px) {
          .phone-container {
            animation: flyInFromLeftPhone 1.5s forwards 0.5s; /* Keep delay on desktop */
          }

          .underline-animation {
            display: inline-block;
            background-image: linear-gradient(120deg, #03a9f4, #9c27b0);
            background-repeat: no-repeat;
            background-size: 100% 3px;
            background-position: 0 88%;
            transition: background-size 0.3s ease-in-out;
          }

          .underline-animation:hover {
            background-size: 100% 100%;
          }
        }

        /* Keyframes for mobile (on scroll) */
        @keyframes flyInFromLeftPhone {
          0% {
            transform: translateX(-150%);
            opacity: 0;
          }
          100% {
            transform: translateX(0);
            opacity: 1;
          }
        }

        /* Initial state for the second phone container */
        .phone-container-second {
          transform: translateX(-150%); /* Positioned off-screen to the left */
          opacity: 0; /* Initially hidden */
          transition:
            transform 1.5s ease-out,
            opacity 1.5s ease-out;
        }

        /* Fly-in effect when in view */
        .fly-in-second {
          transform: translateX(0); /* Return to original position */
          opacity: 1; /* Fully visible */
        }
      </style>

      <script>
        document.addEventListener("DOMContentLoaded", function () {
          const phoneImage = document.querySelector(".phone-container")

          // Detect if the element is in view for mobile
          function isInViewPort(element) {
            const rect = element.getBoundingClientRect()
            return (
              rect.top <=
                (window.innerHeight || document.documentElement.clientHeight) &&
              rect.bottom >= 0
            )
          }

          // Add event listener for scroll to trigger the animation
          window.addEventListener("scroll", function () {
            if (window.innerWidth < 768) {
              // Only apply for mobile view
              if (isInViewPort(phoneImage)) {
                phoneImage.classList.add("fly-in")
              }
            }
          })
        })

        document.addEventListener("DOMContentLoaded", function () {
          const secondPhoneImage = document.querySelector(
            ".phone-container-second"
          )

          // Function to check if the element is in the viewport
          function isInViewPort(element) {
            const rect = element.getBoundingClientRect()
            return (
              rect.top <=
                (window.innerHeight || document.documentElement.clientHeight) &&
              rect.bottom >= 0
            )
          }

          // Function to add the fly-in class when in view
          function handleScroll() {
            if (isInViewPort(secondPhoneImage)) {
              secondPhoneImage.classList.add("fly-in-second")
            }
          }

          // Add scroll event listener
          window.addEventListener("scroll", handleScroll)

          // Run on page load in case the element is already in view
          handleScroll()
        })
      </script>
    </div>
  </div>
</MainLayout>
