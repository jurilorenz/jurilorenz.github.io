---
import MainLayout from "../layouts/MainLayout.astro"
import IpadComponent from "../components/IpadComponent.astro"
import MotionSection from "../components/MotionSection.astro";
import ImageBanner from "../components/ImageBanner.astro";
import FeatureGridSection from "../components/FeatureGridSection.astro";
import BarSection from "../components/BarSection.astro";
import LongformSection from "../components/LongformSection.astro";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Website-Optimierung",
    image: "https://maxwapp.de/images/maxwapp-website-optimierung.webp",
    description:
      "Optimierung bestehender Websites mit Fokus auf SEO, Geschwindigkeit, Conversion und Technik.",
    brand: {
      "@type": "Brand",
      name: "maxWapp",
    },
    offers: {
      "@type": "Offer",
      priceCurrency: "EUR",
      price: "600",
      availability: "https://schema.org/InStock",
      url: "https://maxwapp.de/website-optimieren-muenchen/",
    },
  },
]
---

<MainLayout
  title="Website optimieren München: SEO, Speed & Conversion | maxWapp"
  seoTitle="Website optimieren München: SEO, Speed & Conversion"
  seoDesc="Website optimieren lassen in München: bessere Google-Sichtbarkeit, schnellere Ladezeit und mehr Anfragen. Kostenloses Audit + klarer Maßnahmenplan."
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <!-- Hintergrund mit Verlauf -->
  <div
    class="min-h-screen bg-gradient-to-b from-[#090a1a] to-[#290065] text-white text-center flex flex-col items-center justify-center"
  >
    <!-- Titel -->
    <h1
      class="text-center text-3xl md:text-6xl font-bold text-gray-100 drop-shadow-lg mt-12 md:mb-12 md:mt-36"
    >
      Website optimieren in München
    </h1>

    <!-- Inhalt Abschnitt -->
    <div
      class="w-11/12 md:w-10/12 lg:w-8/12 mx-auto text-lg md:text-xl text-gray-300 leading-relaxed mt-12 flex flex-col-reverse md:flex-row items-center gap-16 md:gap-32"
    >
      <!-- Handybildabschnitt für Desktop links -->
      <div
        class="w-full md:w-5/12 flex justify-center md:justify-end mb-12 md:mb-0 rounded shadow-md drop-shadow-[-35px_0px_35px_rgba(75,0,130,0.6)] phone-container"
      >
        <img
          src="/images/maxwapp-website-optimierung.webp"
          alt="Website-Optimierung Screenshot – Beispielansicht (maxWapp)"
          class="w-80 md:w-auto md:max-h-[60vh] object-contain rounded-lg"
        />
      </div>

      <!-- Textabschnitt für Desktop rechts -->
      <div class="w-full md:w-5/12 text-center md:text-left">
        <p class="text-xl md:text-2xl mt-4">
          Deine Website wird gefunden – aber sie lädt zu langsam, wirkt unklar oder bringt zu wenig Anfragen?
          Ich finde die größten Bremsen und optimiere gezielt: <strong>SEO</strong>, <strong>Speed</strong>
          und <strong>Conversion</strong>.
        </p>

        <p class="text-xl md:text-2xl mt-8">
          Ob <strong>technisches Feintuning</strong>, <strong
            >Conversion-Optimierung</strong
          > oder <strong>SEO-Boost</strong> – schon kleine Anpassungen können <span
            class="text-gradient font-semibold">große Wirkung</span
          > zeigen. Du entscheidest, wie tief wir einsteigen.
        </p>

        <p class="text-xl md:text-2xl mt-8">
        Start mit <strong>kostenloser Ersteinschätzung</strong>: Audit von Speed & Stabilität (Ladezeit, flüssige Bedienung, Layout bleibt ruhig), Informationsarchitektur und Inhalten. Danach erhältst du einen klaren Maßnahmenplan.
        </p>
      </div>
    </div>

    <!-- Was ich biete Abschnitt mit Karten -->
    <h2 class="text-center text-4xl md:text-5xl font-extrabold my-24">
      Was ich biete
    </h2>

    <div
      class="grid grid-cols-1 md:grid-cols-2 gap-12 px-6 md:px-0 max-w-6xl mx-auto"
    >
      <!-- Karte 1: Shop-Redesign mit Conversion-Fokus -->
      <div
        class="relative bg-[#1b1b33] p-8 rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)]"
      >
        <div
          class="absolute top-0 left-0 bg-gradient-to-r from-purple-400 to-blue-500 w-full h-2 rounded-t-xl"
        >
        </div>
        <h4 class="text-3xl font-bold text-white mb-6">
          Conversion-Optimierung
        </h4>
        <p class="text-lg text-gray-300 leading-relaxed">
          Deine Seite wird besucht, aber es passiert nichts? Ich optimiere <strong
            >Struktur, Design & Calls-to-Action</strong
          >, damit Besucher auch wirklich Kunden werden.
        </p>
      </div>

      <!-- Karte 2: Shopify Setup & Startklar-Paket -->
      <div
        class="relative bg-[#1b1b33] p-8 rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)]"
      >
        <div
          class="absolute top-0 left-0 bg-gradient-to-r from-purple-400 to-blue-500 w-full h-2 rounded-t-xl"
        >
        </div>
        <h4 class="text-3xl font-bold text-white mb-6">Pagespeed & Technik</h4>
        <p class="text-lg text-gray-300 leading-relaxed">
          Ich beschleunige deine Website und sorge für sauberen Code – <strong
            >schneller Laden = bessere Rankings + bessere UX</strong
          >. Auch Google liebt Performance.
        </p>
      </div>

      <!-- Karte 3: Mobile-First & Conversion-Ready -->
      <div
        class="relative bg-[#1b1b33] p-8 rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)]"
      >
        <div
          class="absolute top-0 left-0 bg-gradient-to-r from-purple-400 to-blue-500 w-full h-2 rounded-t-xl"
        >
        </div>
        <h4 class="text-3xl font-bold text-white mb-6">Mobile-Optimierung</h4>
        <p class="text-lg text-gray-300 leading-relaxed">
          Ohne mobile Optimierung keine Sichtbarkeit: Ich mache deine Website <strong
            >mobilfreundlich, schnell & responsive</strong
          > – perfekt für Smartphone & Tablet.
        </p>
      </div>

      <!-- Karte 4: Barrierefreies Webdesign -->
      <div
        class="relative bg-[#1b1b33] p-8 rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)]"
      >
        <div
          class="absolute top-0 left-0 bg-gradient-to-r from-purple-400 to-blue-500 w-full h-2 rounded-t-xl"
        >
        </div>
        <h4 class="text-3xl font-bold text-white mb-6">
          Barrierefreies Webdesign
        </h4>
        <p class="text-lg text-gray-300 leading-relaxed">
          Ich sorge dafür, dass deine Website <strong
            >auch für Menschen mit Einschränkungen zugänglich</strong
          > ist – inklusive klarer Strukturen, guter Lesbarkeit und technischer Standards.
        </p>
      </div>
    </div>

    <h2
      class="text-center text-3xl md:text-4xl font-extrabold mt-36 mb-12 mx-2"
      style="line-height: 1.3;"
    >
      Kleine Änderungen – große Wirkung
    </h2>

    <p class="text-xl md:text-2xl text-gray-300 text-center max-w-4xl mx-2">
      Schon <strong>kleine Optimierungen</strong> können zu mehr Sichtbarkeit, Anfragen
      und <span class="underline-animation">Umsatz</span> führen. Ich analysiere
      deine Seite 
      <span class="text-gradient font-semibold">kostenfrei</span> und setze gezielte Verbesserungen um.
    </p>
    <p
      class="text-xl md:text-2xl text-gray-300 text-center max-w-4xl mx-2 mt-6"
    >
      Du willst deine bestehende Seite <strong>für Google optimieren</strong> und gleichzeitig die Nutzerführung verbessern?
      Ich priorisiere die Maßnahmen so, dass du schnell Effekte siehst – und die Basis langfristig stabil bleibt.
    </p>

<MotionSection
  eyebrow="SEO & Performance"
  title="Optimierung bringt Wirkung, wenn sie systematisch ist"
  intro="Viele ‚optimieren‘ nur oberflächlich: ein Plugin, ein paar Texte, fertig. Ergebnisse kommen erst, wenn SEO-Basis, Ladezeit und Nutzerführung zusammenpassen. Ich starte mit einem Audit und setze Maßnahmen so um, dass Google es sauber einordnen kann – und Besucher schneller anfragen."
  points={[
    "Performance & PageSpeed verbessern (schneller laden, flüssiger bedienen)",
    "SEO-Basis sauber machen (Titles, Struktur, interne Links)",
    "Conversion erhöhen (CTAs, Trust, Kontaktwege, Mobile-Flow)",
  ]}
  imgSrc="/images/freelancer-wordpress-schnelle-umsetzung-rakete.webp"
  imgAlt="Website optimieren: SEO, Performance und Conversion systematisch verbessern – maxWapp"
  ctaLabel="Kostenloses Audit starten"
  ctaHref="/kontakt"
  compact={true}
/>

<h2 class="text-center text-3xl md:text-4xl font-extrabold mt-24 mb-12 mx-2" style="line-height: 1.3;">
  Was ich konkret optimiere
</h2>

<ul class="text-xl md:text-2xl text-gray-300 max-w-3xl mx-4 list-disc pl-6 space-y-3 text-left leading-relaxed">
  <li><strong>SEO-Basis:</strong> Titles/Meta, Überschriften, interne Links</li>
  <li><strong>Technik:</strong> Indexierung, Fehler, Weiterleitungen</li>
  <li><strong>Content:</strong> Klarheit, Nutzen, FAQ</li>
  <li><strong>Conversion:</strong> CTAs, Trust, Kontaktwege, mobile Nutzerführung</li>
    <li><strong>Core Web Vitals:</strong> Bilder, Scripts, Caching, Ladezeit</li>

</ul>

<LongformSection
  eyebrow="Lokale Sichtbarkeit"
  title="Website + Google Maps = lokale Anfragen"

  topText={`<p>Für lokale Unternehmen beginnt die Suche heute fast immer bei <strong>Google</strong> – oft direkt in <strong>Google Maps</strong>. Noch bevor jemand deine Website besucht, entscheidet dein <strong>Google Business Profil</strong>, ob dein Unternehmen überhaupt gesehen wird.</p>

<p>Viele Firmen investieren Zeit und Geld in ihre Website, lassen aber das Google Profil halb eingerichtet. Falsche Kategorien, fehlende Leistungen, kaum Bilder oder Bewertungen – dadurch verliert das Unternehmen genau dort Sichtbarkeit, wo Kunden aktiv suchen.</p>

<p>Eine starke lokale Präsenz entsteht erst, wenn <strong>Website und Google Business Profil zusammenarbeiten</strong>: Das Profil bringt Sichtbarkeit in der Suche – die Website sorgt für Vertrauen und verwandelt Besucher in Anfragen.</p>`}

  imgSrc="/images/google-maps-lokale-sichtbarkeit.webp"
  imgAlt="Google Maps Unternehmensprofil und Website sorgen zusammen für lokale Sichtbarkeit"
  caption="Lokale Sichtbarkeit entsteht durch das Zusammenspiel von Google Business Profil und Website."

bottomText={`<p>Ein entscheidender Faktor für lokale Sichtbarkeit sind <strong>Google Bewertungen</strong>. Sie beeinflussen nicht nur das Vertrauen potenzieller Kunden, sondern auch, wie sichtbar dein Unternehmen in <strong>Google Maps</strong> und in der lokalen Suche erscheint.</p>

<p>Viele Unternehmen haben zwar ein Google Profil, aber zu wenige Bewertungen oder keine klare Strategie, wie neue Bewertungen entstehen. Genau hier verliert man oft Sichtbarkeit gegenüber Wettbewerbern.</p>

<p>Deshalb gehört zu einer starken lokalen Präsenz auch eine <strong>strukturierte Strategie für Google Bewertungen</strong>: Wie Kunden Bewertungen hinterlassen, wie Vertrauen aufgebaut wird und wie dein Profil dadurch besser rankt.</p>`}

ctaLabel="Google Bewertungen verbessern"
ctaHref="/google-bewertungen-verbessern"
/>

<!-- Optimierungs-Prozess als Karten (B2C-freundlich) -->
<h2 class="text-center text-3xl md:text-4xl font-extrabold mt-12 mb-12 mx-2" style="line-height:1.3;">
  Website optimieren – so läuft’s ab
</h2>

<div class="grid grid-cols-1 md:grid-cols-2 gap-12 px-6 md:px-0 max-w-6xl mx-auto">
  <!-- Karte 1 -->
  <div class="relative bg-[#1b1b33] p-8 rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)]">
    <div class="absolute top-0 left-0 bg-gradient-to-r from-purple-400 to-blue-500 w-full h-2 rounded-t-xl"></div>
    <h4 class="text-2xl md:text-3xl font-bold text-white mb-4">
      <span class="text-gradient">1.</span> Audit & Prioritäten
    </h4>
    <p class="text-lg text-gray-300 leading-relaxed">
      Quick-Check von <strong>Speed & Stabilität</strong>, technischen Fehlern, Indexierung, internen Links und Content.
      Danach bekommst du eine klare Prioritätenliste: <em>Was bringt am schnellsten Wirkung?</em>
    </p>
  </div>

  <!-- Karte 2 -->
  <div class="relative bg-[#1b1b33] p-8 rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)]">
    <div class="absolute top-0 left-0 bg-gradient-to-r from-purple-400 to-blue-500 w-full h-2 rounded-t-xl"></div>
    <h4 class="text-2xl md:text-3xl font-bold text-white mb-4">
      <span class="text-gradient">2.</span> SEO-Quickwins
    </h4>
    <p class="text-lg text-gray-300 leading-relaxed">
      Titel/Meta feinjustieren, Überschriften strukturieren, Snippets verbessern, interne Verlinkung stärken.
      Ziel: bessere Relevanz für Google – ohne Keyword-Text.
    </p>
  </div>

  <!-- Karte 3 -->
  <div class="relative bg-[#1b1b33] p-8 rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)]">
    <div class="absolute top-0 left-0 bg-gradient-to-r from-purple-400 to-blue-500 w-full h-2 rounded-t-xl"></div>
    <h4 class="text-2xl md:text-3xl font-bold text-white mb-4">
      <span class="text-gradient">3.</span> Speed & Technik
    </h4>
    <p class="text-lg text-gray-300 leading-relaxed">
      Bilder/Assets optimieren, unnötige Skripte reduzieren, Caching sauber setzen und Probleme finden,
      die LCP/INP/CLS verschlechtern. Ergebnis: schnellere Website und bessere UX.
    </p>
  </div>

  <!-- Karte 4 -->
  <div class="relative bg-[#1b1b33] p-8 rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)]">
    <div class="absolute top-0 left-0 bg-gradient-to-r from-purple-400 to-blue-500 w-full h-2 rounded-t-xl"></div>
    <h4 class="text-2xl md:text-3xl font-bold text-white mb-4">
      <span class="text-gradient">4.</span> Conversion & Feinschliff
    </h4>
    <p class="text-lg text-gray-300 leading-relaxed">
      CTAs, Trust-Elemente und Nutzerführung so anpassen, dass Besucher schneller verstehen,
      was du anbietest – und leichter anfragen. Danach: Testing + kleine Iterationen.
    </p>
  </div>
</div>

<!-- CTA-Karte (ohne Preise) -->
<div class="max-w-6xl mx-auto px-6 md:px-0 mt-8">
  <div class="relative bg-[#13132a] p-6 md:p-8 rounded-xl border border-gray-700 text-center shadow-[0px_0px_35px_rgba(147,112,219,0.35)]">
    <div class="absolute top-0 left-0 bg-gradient-to-r from-purple-400 to-blue-500 w-full h-1 rounded-t-xl"></div>
    <p class="text-base md:text-lg text-gray-200">
      Starte mit einer <a href="/kontakt" class="underline underline-offset-4 decoration-2">kostenlosen Potenzialanalyse</a> –
      10–15 konkrete Ideen, wie du <strong>SEO</strong>, <strong>Speed</strong> und <strong>Conversion</strong> schnell verbessern kannst.
    </p>
  </div>
</div>


<IpadComponent
  imgSrc="/images/ipad-pagespeed-test-maxwapp.webp"
  imgAlt="Screenshot: Google PageSpeed Insights – Ergebnis für maxWapp"
/>

<BarSection
  eyebrow="Vertrauen"
  title="Warum du mir die Optimierung deiner Website anvertrauen kannst"
  intro="Website-Optimierung ist kein „Plugin rein, fertig“. Ich arbeite strukturiert: Audit, Prioritäten, saubere Umsetzung und messbare Verbesserungen bei SEO, Ladezeit und Anfragen – ohne Agentur-Overhead."
  badges={[
    { label: "70+ Bewertungen", sublabel: "Google", href: "https://maps.app.goo.gl/93PpiX2gyiVCfcGd7" },
    { label: "5.0 Sterne", sublabel: "Top Rating", href: "https://maps.app.goo.gl/93PpiX2gyiVCfcGd7" },
    { label: "Klar & Fair", sublabel: "Transparente Preise", href: "/preise" },
    { label: "Direkt mit mir", sublabel: "kein Agentur-Overhead", href: "/kontakt" },
  ]}
  note="Du bekommst eine klare Analyse, verständliche Empfehlungen und eine Umsetzung, die technisch sauber bleibt – damit deine Website schneller lädt, besser gefunden wird und mehr Anfragen erzeugt."
/>

<FeatureGridSection
  title="Typische Optimierungs-Fehler – und wie ich sie löse"
  intro="Viele Websites haben Traffic, aber verlieren Potenzial durch Technik, Struktur oder unklare Nutzerführung. Diese Punkte fixen wir gezielt."
  features={[
    {
      title: "1. SEO ohne saubere Basis",
      description:
        "Titles/Meta und Überschriften sind inkonsistent, interne Links fehlen. Ich setze eine klare Struktur, damit Google die Seite korrekt einordnet.",
    },
    {
      title: "2. Speed & Stabilität werden ignoriert",
      description:
        "LCP/INP/CLS sind Ranking- und UX-Signale. Ich finde die echten Bremsen (Bilder, Skripte, Layout-Shifts) und optimiere messbar.",
    },
    {
      title: "3. Content ist da – aber nicht scharf",
      description:
        "Zu viel Text ohne Nutzen, zu wenig klare Aussagen. Ich schärfe Inhalte, baue FAQ sinnvoll aus und entferne Keyword-Fülltext.",
    },
    {
      title: "4. Besucher finden den nächsten Schritt nicht",
      description:
        "CTAs, Trust und Kontaktwege sind oft versteckt. Ich optimiere den Flow (auch mobil), damit aus Besuchern Anfragen werden.",
    },
  ]}
  cols={2}
  ctaLabel="Kostenloses Audit sichern"
  ctaHref="/kontakt"
/>



<ImageBanner
  imgSrc="/images/landingpage-performance-workspace.webp"
  imgAlt="Website Optimierung Arbeitsplatz – Analyse von Performance, Struktur und SEO"
  eyebrow="Performance & Sichtbarkeit"
  title="Website optimieren statt komplett neu bauen"
  text={`
    <p>Viele Websites brauchen keinen kompletten Relaunch. Oft reicht eine gezielte <strong>Website Optimierung</strong>, um Struktur, Ladezeit und Sichtbarkeit deutlich zu verbessern.</p>

    <p>Ich analysiere zuerst deine aktuelle Website: Performance, Inhalte, SEO-Struktur und Nutzerführung. Danach setze ich gezielt Maßnahmen um – damit deine Website schneller lädt, klarer wirkt und besser bei Google gefunden wird.</p>

    <p>Das Ergebnis: <strong>mehr Sichtbarkeit, bessere Nutzerführung und mehr Anfragen</strong> – ohne unnötig komplizierten Relaunch.</p>
  `}
  ctaLabel="Website analysieren"
  ctaHref="/kontakt"
/>

  <!-- FAQ (карточки тем же стилем) -->
  <h2 class="text-center text-4xl md:text-5xl font-extrabold md:mt-24 mt-12 mb-24">
    Häufige Fragen zur Website-Optimierung
  </h2>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-12 px-6 md:px-0 max-w-6xl mx-auto">
    <div class="relative bg-[#1b1b33] p-8 rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)]">
      <div class="absolute top-0 left-0 bg-gradient-to-r from-purple-400 to-blue-500 w-full h-2 rounded-t-xl"></div>
      <h4 class="text-3xl font-bold text-white mb-6">Wie optimiere ich meine Website für Google?</h4>
      <p class="text-lg text-gray-300 leading-relaxed">Technik + Content + interne Verlinkung. Ich starte mit einem Audit und setze Quick-Wins um, die Google und Nutzer sofort merken.</p>
    </div>

    <div class="relative bg-[#1b1b33] p-8 rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)]">
      <div class="absolute top-0 left-0 bg-gradient-to-r from-purple-400 to-blue-500 w-full h-2 rounded-t-xl"></div>
      <h4 class="text-3xl font-bold text-white mb-6">Was sind die wichtigsten SEO-Quickwins?</h4>
      <p class="text-lg text-gray-300 leading-relaxed">Titles/Meta, klare H-Struktur, interne Links, Snippet-Optimierung und saubere Indexierbarkeit. Priorisiert nach Wirkung.</p>
    </div>

    <div class="relative bg-[#1b1b33] p-8 rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)]">
      <div class="absolute top-0 left-0 bg-gradient-to-r from-purple-400 to-blue-500 w-full h-2 rounded-t-xl"></div>
      <h4 class="text-3xl font-bold text-white mb-6">Was bringt mehr: Speed oder Content?</h4>
      <p class="text-lg text-gray-300 leading-relaxed">Beides. Speed verbessert UX und Rankingsignale, Content bringt Relevanz. Ich kombiniere: erst Bremsen lösen, dann Inhalte schärfen.</p>
    </div>

    <div class="relative bg-[#1b1b33] p-8 rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)]">
