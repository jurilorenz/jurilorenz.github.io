---
import MainLayout from "../../layouts/MainLayout.astro";
import { blogPosts } from "../../data/blogPosts";
import FinalCTASection from "../../components/FinalCTASection.astro";


const { slug } = Astro.params;
const post = blogPosts.find(p => p.slug === slug);

if (!post) {
  throw new Error(`Post not found for slug: ${slug}`);
}
const hasSections = Array.isArray(post?.sections) && post.sections.length > 0;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.title,
  "description": post.seoDesc,
  "image": `https://maxwapp.de${post.image}`,
  "author": {
    "@type": "Person",
    "name": "Juri Lorenz",
    "url": "https://maxwapp.de/#ueber-mich"
  },
  "publisher": {
    "@type": "Organization",
    "name": "maxWapp",
    "logo": {
      "@type": "ImageObject",
      "url": "https://maxwapp.de/images/logo.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://maxwapp.de/webdesign-blog/${post.slug}/`
  }
};

export async function getStaticPaths() {
  const { blogPosts } = await import("../../data/blogPosts");

  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: post
  }));
}
---

<MainLayout title={post.title} seoTitle={post.seoTitle} seoDesc={post.seoDesc}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <article class="min-h-screen text-white pb-20 px-4 max-w-4xl mx-auto">
    <h1 class="text-center mw-h2 mt-12 md:mt-36 mb-8 mx-2">
      {post.title}
    </h1>

    <p class="text-center mw-lead px-4 mb-16 max-w-4xl mx-auto">
      {post.intro}
    </p>

    <img src={post.image} alt={post.title} class="media-rounded shadow-purple-drop object-contain w-full h-auto max-h-[90vh] mb-12" />

    {hasSections ? (
      post.sections.map((section) => (
        <section class="mt-12 space-y-5">
          {section.title && (
            <h2 class="mw-h2-compact">
              {section.title}
            </h2>
          )}

          {section.intro && (
            <p class="mw-lead">
              {section.intro}
            </p>
          )}

          <div class="mw-body whitespace-pre-line">
            {section.body}
          </div>

          {section.image && (
            <img
              src={section.image}
              alt={section.imageAlt || section.title || post.title}
              class="media-rounded shadow-purple-drop object-contain w-full h-auto max-h-[90vh] mt-6"
              loading="lazy"
            />
          )}
        </section>
      ))
    ) : (
      <>
        {post.body && (
          <div class="mw-body whitespace-pre-line mb-6">
            {post.body}
          </div>
        )}

        {(post.body2Title || post.body2Intro) && (
          <div class="mb-10 mt-20">
            {post.body2Title && (
              <h2 class="mw-h2-compact mb-4">{post.body2Title}</h2>
            )}
            {post.body2Intro && (
              <p class="mw-lead mb-8">{post.body2Intro}</p>
            )}
          </div>
        )}

        {post.image2 && (
          <img
            src={post.image2}
            alt={post.image2Alt || post.title}
            class="media-rounded shadow-purple-drop object-contain w-full h-auto max-h-[90vh] mb-12 mt-16"
            loading="lazy"
          />
        )}

        {post.body2 && (
          <div class="mw-body whitespace-pre-line mb-6">
            {post.body2}
          </div>
        )}
      </>
    )}

    {post.quote && (
      <blockquote class="mt-12 mb-16 pl-6 border-l-4 border-purple-400">
        <p class="mw-body italic text-gray-300">
          {post.quote}
        </p>
      </blockquote>
    )}

{post.ctaText && post.ctaLink && (
  <div class="mw-blog-cta mt-12">
    <p class="mw-blog-cta-copy">{post.ctaText}</p>
    <div class="mw-blog-cta-actions">
      <a href={post.ctaLink} class="mw-blog-link-btn" target={post.ctaLink.startsWith('http') ? '_blank' : '_self'} rel="noopener noreferrer">
        Zum Page
      </a>
    </div>
  </div>
)}

    <p class="mw-eyebrow mt-12">Kategorie: {post.category}</p>

  
</MainLayout>



<FinalCTASection
  eyebrow="Kostenlose Analyse"
  title="Lass uns deine Website strategisch anschauen"
  description={`
    <p>Ob neue Website, Relaunch oder Optimierung – oft liegt das Potenzial nicht im Design, sondern in Struktur, Klarheit und Conversion.</p>
  `}
  ctaLabel="Kostenlos beraten lassen"
  ctaHref="/kontakt"
/>


<style>


  body {
    font-family: "Poppins", sans-serif;
  }
</style>
