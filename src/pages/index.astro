    <!-- Hero Section -->
<PrimaryHeroSection
  title="Professionelles Webdesign aus München"
  lead="Ich entwickle professionelle Websites, Landingpages und Onlineshops für lokale Unternehmen – klar strukturiert, sichtbar bei Google und auf Anfragen ausgerichtet."
leadMobile="Ich entwickle professionelle Websites – klar strukturiert, sichtbar bei Google und auf Anfragen ausgerichtet."  desktopImgSrc="/images/home-page-juri-lorenz-desktop.webp"
  mobileImgSrc="/images/home-page-juri-lorenz-mobile.webp"
  imgAlt="Juri Lorenz – professionelles Webdesign aus München"
  ctaLabel="Kostenloses Erstgespräch"
  ctaHref="/kontakt"
/>

<p class="sr-only">
  Webdesign München: Erstellung moderner, responsiver Websites und Landingpages für Unternehmen. Fokus auf klare Struktur, schnelle Ladezeiten und gute Auffindbarkeit bei Google. Leistungen: Website erstellen lassen, WordPress Websites, Landingpages und Onlineshops in München und Umgebung.
</p>
            <!-- Services Section -->
            <ServicesComponent />

<SolutionSection
  title="Warum Unternehmen ihre Website mit maxWapp umsetzen"
intro="Du brauchst keine Website, die nur gut aussieht. Du brauchst einen Auftritt, der professionell wirkt, Vertrauen schafft und neue Anfragen bringt."  steps={[
{
  num: "1",
  title: "Du brauchst nichts vorzubereiten",
  text: "Ich übernehme alles – von Struktur und Texten bis zu Bildern und Umsetzung. Du musst nur entscheiden, dass du starten willst.",
},
{
  num: "2",
title: "Minimaler Aufwand für dich",
text: "Du musst dich nicht in Details einarbeiten oder ständig abstimmen – ich halte den Prozess schlank und bringe dein Projekt effizient voran."},
    {
      num: "3",
      title: "Dein Angebot wird klar präsentiert",
      text: "Besucher sollen sofort verstehen, was du anbietest, warum sie dir vertrauen können und was der nächste Schritt ist.",
    },
    {
      num: "4",
      title: "Die Website soll Ergebnisse bringen",
      text: "Mehr Sichtbarkeit, mehr Vertrauen und mehr Anfragen – genau darauf ist der Aufbau ausgerichtet.",
    },
  ]}
  ctaLabel="Projekt besprechen"
  ctaHref="/kontakt"
/>

             <!-- Devices Section -->
             <DevicesComponent />

<TestimonialsComponent />

<AboutCompactSection />

<FeatureGridSection
  title="So läuft dein Projekt ab"
  intro="Klare Schritte, feste Kosten und minimale Abstimmung – damit du schnell zu einer Website kommst, die professionell wirkt und Anfragen bringt."
  features={[
    {
      title: "1. Kostenlose Erstberatung",
      description: "Wir klären dein Ziel, dein Angebot und was deine Website leisten soll – du bekommst eine klare Einschätzung."
    },
    {
      title: "2. Festpreisangebot",
      description: "Du erhältst ein transparentes Angebot mit klarem Umfang – ohne versteckte Kosten oder offene Punkte."
    },
    {
      title: "3. Inhalte & Umsetzung",
      description: "Struktur, Design und Inhalte entwickle ich für dich und setze alles effizient um – abgestimmt auf dein Feedback und deine Anforderungen."
    },
    {
      title: "4. Launch & Ergebnisse",
      description: "Deine Website geht live und ist darauf ausgerichtet, Vertrauen aufzubauen und Anfragen zu generieren."
    }
  ]}
  cols={2}
  compact={true}
  center={true}
afterText={`Die Umsetzung dauert in der Regel 2–4 Wochen – da Struktur, Inhalte und Umsetzung aus einer Hand kommen, bleibt der Prozess schnell und effizient. Wenn du vorher eine schnelle Orientierung zu den Kosten willst, nutze den <a href="/preise" class="underline underline-offset-4">Preisrechner</a>.`}
  ctaLabel="Projekt starten"
  ctaHref="/kontakt"
/>

<FinalCTASection
  title="Bereit für eine Website, die Anfragen bringt?"
  description={`
    <p class="mt-4">In einem kurzen Erstgespräch klären wir, was für dein Business sinnvoll ist – und wie du schnell zu einer Website kommst, die professionell wirkt, Vertrauen aufbaut und gezielt Anfragen bringt.</p>
  `}
  ctaLabel="Kostenloses Erstgespräch"
  ctaHref="/kontakt"
/>

 </MainLayout
>