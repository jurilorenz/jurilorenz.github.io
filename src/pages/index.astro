---
import MainLayout from "../layouts/MainLayout.astro";
import DevicesComponent from '../components/DevicesComponent.astro';
import ServicesComponent from '../components/ServicesComponent.astro';
import HeroComponent from "../components/HeroComponent.astro";
import TestimonialsComponent from "../components/TestimonialsComponent.astro";
import FinalCTASection from "../components/FinalCTASection.astro";

---

<MainLayout 
title="Professionelles Webdesign München – Websites, die verkaufen | maxWapp"
seoTitle="Professionelles Webdesign München – Top Websites | maxWapp"
  seoDesc="Professionelles Webdesign aus München: moderne, schnelle und SEO-optimierte Websites für Unternehmen – mit Fokus auf Sichtbarkeit, Performance und Conversions."
>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": "https://maxwapp.de#business",
      "name": "maxWapp",
      "image": "https://maxwapp.de/images/logo.png",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Constanze-Hallgarten Str. 40",
        "addressLocality": "München",
        "postalCode": "81379",
        "addressCountry": "DE"
      },
      "url": "https://maxwapp.de",
      "telephone": "+49 1777 59 48 39",
      "priceRange": "€€",
      "openingHours": "Mo-Fr 08:00-18:00",
      "sameAs": [
        "https://www.instagram.com/maxwapp.de",
        "https://www.linkedin.com/in/juri-lorenz"
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
