---
// ServicesComponent.astro
---

<div class="min-h-screen text-white pb-12 md:py-28">
  <div
    class="text-center md:text-left w-11/12 md:w-10/12 lg:w-full max-w-7xl mx-auto mt-6 md:mt-0"
  >
    <!-- Content Section -->
    <div class="min-h-screen text-white py-20 md:py-10">
      <div class="w-full mx-auto text-center">


        <h2
        class="text-center text-4xl md:text-6xl font-bold text-gray-100 drop-shadow-lg mb-12 md:mb-28"
        >
Was ich biete        </h2>

        <!-- Service Cards Horizontal -->
        <div class="flex flex-wrap justify-center gap-6">
          <a href="/wordpress-website-erstellen-lassen" class="group relative bg-[#1b1b33] rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)] transition-all hover:scale-[1.03] hover:shadow-none w-full max-w-xs p-6 text-left overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-purple-400 to-blue-500 rounded-t-xl transition-opacity duration-300"></div>
            <h3 class="text-2xl font-bold text-white mb-2">WordPress Website</h3>
            <p class="text-gray-300 leading-relaxed text-base">
              Professionelle Website auf WordPress – klar strukturiert, schnell und auf Anfragen optimiert.
            </p>
            <p class="mt-4 text-sm font-medium text-[#6d87d1]">→ Mehr erfahren</p>
          </a>
        
          <a href="/landingpage-erstellen-lassen" class="group relative bg-[#1b1b33] rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)] transition-all hover:scale-[1.03] hover:shadow-none w-full max-w-xs p-6 text-left overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-purple-400 to-blue-500 rounded-t-xl transition-opacity duration-300"></div>
            <h3 class="text-2xl font-bold text-white mb-2">Landingpage</h3>
            <p class="text-gray-300 leading-relaxed text-base">
              Fokus auf ein Ziel: klare Botschaft, starke CTAs und ein Flow, der Besucher zu Leads macht.
            </p>
            <p class="mt-4 text-sm font-medium text-[#6d87d1]">→ Mehr erfahren</p>
          </a>
        
          <a href="/online-shop-erstellen-lassen" class="group relative bg-[#1b1b33] rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)] transition-all hover:scale-[1.03] hover:shadow-none w-full max-w-xs p-6 text-left overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-purple-400 to-blue-500 rounded-t-xl transition-opacity duration-300"></div>
            <h3 class="text-2xl font-bold text-white mb-2">Online‑Shop</h3>
            <p class="text-gray-300 leading-relaxed text-base">
              Shopify oder WooCommerce – sauber aufgebaut, schnell und verkaufsorientiert.
            </p>
            <p class="mt-4 text-sm font-medium text-[#6d87d1]">→ Mehr erfahren</p>
          </a>
        
          <a href="/website-relaunch-redesign" class="group relative bg-[#1b1b33] rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)] transition-all hover:scale-[1.03] hover:shadow-none w-full max-w-xs p-6 text-left overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-purple-400 to-blue-500 rounded-t-xl transition-opacity duration-300"></div>
            <h3 class="text-2xl font-bold text-white mb-2">Relaunch & Redesign</h3>
            <p class="text-gray-300 leading-relaxed text-base">
              Wenn die alte Website bremst: neue Struktur, besserer Look und saubere SEO‑Übergabe.
            </p>
            <p class="mt-4 text-sm font-medium text-[#6d87d1]">→ Mehr erfahren</p>
          </a>
        
          <a href="/website-optimieren-muenchen" class="group relative bg-[#1b1b33] rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)] transition-all hover:scale-[1.03] hover:shadow-none w-full max-w-xs p-6 text-left overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-purple-400 to-blue-500 rounded-t-xl transition-opacity duration-300"></div>
            <h3 class="text-2xl font-bold text-white mb-2">Website‑Optimierung</h3>
            <p class="text-gray-300 leading-relaxed text-base">
              SEO, PageSpeed und Conversion verbessern – damit aus Besuchern messbar mehr Anfragen werden.
            </p>
            <p class="mt-4 text-sm font-medium text-[#6d87d1]">→ Mehr erfahren</p>
          </a>
          <a href="/printdesign-muenchen" class="group relative bg-[#1b1b33] rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)] transition-all hover:scale-[1.03] hover:shadow-none w-full max-w-xs p-6 text-left overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-purple-400 to-blue-500 rounded-t-xl transition-opacity duration-300"></div>
            <h3 class="text-2xl font-bold text-white mb-2">Printdesign & CI</h3>
            <p class="text-gray-300 leading-relaxed text-base">
              Visitenkarten, Flyer, Logo & Co. – konsistent zur Marke und druckfertig umgesetzt.
            </p>
            <p class="mt-4 text-sm font-medium text-[#6d87d1]">→ Mehr erfahren</p>
          </a>
        </div>

        <!-- Project Request Button -->
        <div class="mt-20">
          <a
            href="/kontakt"
            class="relative inline-block py-4 px-10 rounded-full font-bold text-center w-full max-w-xs md:max-w-none md:w-auto bg-white text-[#090a1a] shadow-lg transition-all duration-300 ease-in-out hover:shadow-[0_0_20px_rgba(147,112,219,0.8),_0_0_35px_rgba(3,169,244,0.6)] hover:border-[#6d87d1]"
          >
            Projekt anfragen
          </a>
        </div>
      </div>

      <!-- Partnerships & Freelancing Section -->
      <div
        class="relative bg-[#1b1b33] rounded-xl border border-gray-700 shadow-[0px_0px_35px_rgba(147,112,219,0.6)] transition-transform duration-500 py-12 px-6 md:w-9/12 md:mx-auto mt-36 text-center mx-6"
      >
        <div
          class="absolute top-0 left-0 bg-gradient-to-r from-purple-400 to-blue-500 w-full h-2 rounded-t-xl"
        ></div>
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
          Freelancer & Partner
        </h2>
        <p class="text-gray-300 text-xl mt-4 max-w-3xl mx-auto leading-relaxed">
Als Freelancer unterstütze ich Ihr Team mit fundiertem Know-how in Frontend-Entwicklung sowie spezialisierten Fähigkeiten in Marketing und SEO.
        </p>
        <div class="flex flex-col md:flex-row gap-6 mt-8 justify-center items-center w-full">
          <a
            href="/wordpress-freelancer"
            class="bg-[#1f1235] text-white font-bold py-4 px-10 rounded-full border-2 border-[#6d87d1] shadow-lg transition-all duration-300 ease-in-out hover:bg-blue-500 hover:shadow-[0_0_10px_rgba(147,112,219,0.5),_0_0_25px_rgba(3,169,244,0.4)] text-center w-full max-w-xs md:max-w-none md:w-auto"
          >
            Mehr Info
          </a>
          <a
            href="/kontakt"
            class="relative inline-block py-4 px-10 rounded-full font-bold text-center w-full max-w-xs md:max-w-none md:w-auto bg-white text-[#090a1a] shadow-lg transition-all duration-300 ease-in-out hover:shadow-[0_0_20px_rgba(147,112,219,0.8),_0_0_35px_rgba(3,169,244,0.6)] hover:border-[#6d87d1]"
          >
            Let's Talk
          </a>
        </div>
      </div>
    </div>
  </div>
</div>