---
// ServicesComponent.astro

import PrimaryButton from "../components/PrimaryButton.astro";
import SecondaryButton from "../components/SecondaryButton.astro";

---

<div class="section-pad text-white">
  <div class="section-container">
    <div class="w-full text-center">
      <h2 class="mw-h2 mb-12 md:mb-20">
        Was ich biete
      </h2>

      <div class="flex flex-wrap justify-center gap-6">
        <a href="/wordpress-website-erstellen-lassen" class="mw-glass-card group w-full max-w-xs p-6 text-left">
          <div class="mw-topbar-gradient"></div>
          <h3 class="mw-card-section-title mb-2">WordPress Website</h3>
          <p class="mw-muted text-base">
            Professionelle Website auf WordPress – klar strukturiert, schnell und auf Anfragen optimiert.
          </p>
          <p class="mt-4 text-sm font-medium text-[#6d87d1]">→ Mehr erfahren</p>
        </a>
      
        <a href="/landingpage-erstellen-lassen" class="mw-glass-card group w-full max-w-xs p-6 text-left">
          <div class="mw-topbar-gradient"></div>
          <h3 class="mw-card-section-title mb-2">Landingpage</h3>
          <p class="mw-muted text-base">
            Fokus auf ein Ziel: klare Botschaft, starke CTAs und ein Flow, der Besucher zu Leads macht.
          </p>
          <p class="mt-4 text-sm font-medium text-[#6d87d1]">→ Mehr erfahren</p>
        </a>
      
        <a href="/online-shop-erstellen-lassen" class="mw-glass-card group w-full max-w-xs p-6 text-left">
          <div class="mw-topbar-gradient"></div>
          <h3 class="mw-card-section-title mb-2">Online‑Shop</h3>
          <p class="mw-muted text-base">
            Shopify oder WooCommerce – sauber aufgebaut, schnell und verkaufsorientiert.
          </p>
          <p class="mt-4 text-sm font-medium text-[#6d87d1]">→ Mehr erfahren</p>
        </a>
      
        <a href="/website-relaunch-redesign" class="mw-glass-card group w-full max-w-xs p-6 text-left">
          <div class="mw-topbar-gradient"></div>
          <h3 class="mw-card-section-title mb-2">Relaunch & Redesign</h3>
          <p class="mw-muted text-base">
            Wenn die alte Website bremst: neue Struktur, besserer Look und saubere SEO‑Übergabe.
          </p>
          <p class="mt-4 text-sm font-medium text-[#6d87d1]">→ Mehr erfahren</p>
        </a>
      
        <a href="/website-optimieren-muenchen" class="mw-glass-card group w-full max-w-xs p-6 text-left">
          <div class="mw-topbar-gradient"></div>
          <h3 class="mw-card-section-title mb-2">Website optimieren</h3>
          <p class="mw-muted text-base">
            SEO, PageSpeed und Conversion verbessern – damit aus Besuchern messbar mehr Anfragen werden.
          </p>
          <p class="mt-4 text-sm font-medium text-[#6d87d1]">→ Mehr erfahren</p>
        </a>

        <a href="/printdesign-muenchen" class="mw-glass-card group w-full max-w-xs p-6 text-left">
          <div class="mw-topbar-gradient"></div>
          <h3 class="mw-card-section-title mb-2">Printdesign & CI</h3>
          <p class="mw-muted text-base">
            Visitenkarten, Flyer, Logo & Co. – konsistent zur Marke und druckfertig umgesetzt.
          </p>
          <p class="mt-4 text-sm font-medium text-[#6d87d1]">→ Mehr erfahren</p>
        </a>
      </div>

      {true && (
        <div class="mt-16 md:mt-20 flex justify-center">
          <PrimaryButton href="/kontakt" label="Projekt anfragen" />
        </div>
      )}
    </div>

    <div class="mw-glass-card relative py-12 px-6 md:w-9/12 md:mx-auto mt-24 md:mt-28 text-center mx-6">
      <div class="mw-topbar-gradient"></div>
      <h2 class="mw-h2-compact mb-4">
        Freelancer & Partner
      </h2>
      <p class="mw-body text-gray-300 max-w-3xl mx-auto">
        Als Freelancer unterstütze ich Ihr Team mit fundiertem Know-how in Frontend-Entwicklung sowie spezialisierten Fähigkeiten in Marketing und SEO.
      </p>
      <div class="flex flex-col md:flex-row gap-4 md:gap-6 mt-8 justify-center items-center w-full">
        <SecondaryButton href="/wordpress-freelancer" label="Mehr Info" />
        <PrimaryButton href="/kontakt" label="Let's Talk" />
      </div>
    </div>
  </div>
</div>