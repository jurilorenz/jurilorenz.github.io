---
interface Props {
  href: string
  label: string
  fullWidth?: boolean
  target?: "_self" | "_blank"
  rel?: string
  className?: string
  ariaLabel?: string
}

const {
  href,
  label,
  fullWidth = false,
  target = "_self",
  rel = target === "_blank" ? "noopener noreferrer" : undefined,
  className = "",
  ariaLabel,
} = Astro.props
---

<a
  href={href}
  target={target}
  rel={rel}
  aria-label={ariaLabel ?? label}
  class={`relative inline-block py-4 px-10 rounded-full font-bold text-center
  ${fullWidth ? "w-full max-w-xs" : "w-auto"}
  bg-white text-[#090a1a] shadow-lg
  transition-all duration-300 ease-in-out
  hover:shadow-[0_0_20px_rgba(147,112,219,0.8),_0_0_35px_rgba(3,169,244,0.6)]
  hover:border-[#6d87d1]
  ${className}`}
>
  {label}
</a>