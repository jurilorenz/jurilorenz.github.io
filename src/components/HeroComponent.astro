---
const {
  // Text
  title = "Websites,",
  subtitle = "die verkaufen",

  // Images (defaults keep current behavior)
  desktopImgSrc = "/images/home-page-juri-lorenz-desktop.webp",
  mobileImgSrc = "/images/home-page-juri-lorenz-mobile.webp",
  imgAlt = "Juri Lorenz",

  // Bullet points (defaults keep current behavior)
  bulletsDesktop = [
    "Websites und Online-Shops",
    "Mehr Google Sichtbarkeit",
    "Printdesign und Druck",
  ],
  bulletsMobile = [
    "Mehr Google Sichtbarkeit",
    "Websites und Online-Shops",
    "Branding, Logo & Print-Design",
  ],

  // CTA (defaults keep current behavior)
  ctaHref = "/kontakt",
  ctaLabel = "Let's Talk",
} = Astro.props;
---

<!-- Hero Section --><!-- ✅ Десктопная версия -->
<div
  class="hidden md:flex flex-row items-center justify-between min-h-screen px-16 relative gap-x-40"
>
  <!-- Левая часть: Изображение (опускаем вниз) -->
  <div class="w-1/2 flex justify-end items-end mt-48">
    <img
      src={desktopImgSrc}
      class="w-auto h-[80vh] object-cover object-top hero-image"
      alt={imgAlt}
      loading="eager"
      decoding="async"
    />
  </div>

  <!-- Правая часть: Контент (поднимаем вверх) -->
  <div class="w-1/2 flex flex-col items-start text-left mt-12 md:-mt-0">
    <!-- Subtitle with Typing Animation -->
    <a
    href="https://www.google.com/maps/place/maxWapp+%7C+Juri+Lorenz/@48.0961726,11.5084223,17z/data=!3m1!5s0x479dd9218f79d1d3:0x204263009f086393!4m8!3m7!1s0xf3b4b557fd55469:0x893accd647bdc468!8m2!3d48.0961726!4d11.5084223!9m1!1b1!16s%2Fg%2F11wr1981wf?entry=ttu&g_ep=EgoyMDI1MDUwMy4wIKXMDSoJLDEwMjExNDU1SAFQAw%3D%3D"
    target="_blank"
    rel="noopener noreferrer"
class="hidden 2xl:flex flex-col items-start mb-6 rounded-lg transition-all duration-300 hover:shadow-lg hover:shadow-indigo-500/50 p-2"  >
    <div class="flex items-center">
      <div class="text-orange-200 text-2xl">
        ★ ★ ★ ★ ★
      </div>
      <div class="text-gray-300 text-2xl ml-2">
        5.0
      </div>
    </div>
    <div class="text-gray-300 text-xl mt-1 underline">
      über 70 Google-Bewertungen
    </div>
  </a>

  <!-- Заголовок (desktop visual only, no H1 for SEO) -->
  <div class="text-8xl font-bold leading-tight" role="heading" aria-level="2">
    {title}
    <span class="block text-6xl mt-[-0.5rem]">{subtitle}</span>
  </div>
  
    <!-- Список преимуществ -->
    <h2 class="sr-only">Services</h2>
    <ul class="text-lg md:text-2xl mt-10 text-gray-100 space-y-2">
      {bulletsDesktop.map((item) => (
        <li>
          <i class="fas fa-check text-white mr-4"></i>{item}
        </li>
      ))}
    </ul>

    <!-- Кнопка (всегда видна) -->
    <div class="mt-20">
      <a
        href={ctaHref}
        class="bg-gradient-to-r from-purple-500 to-indigo-500 text-white font-bold py-4 px-20 rounded-full shadow-md transition-all duration-300 text-xl tracking-wider ease-in-out hover:brightness-110 hover:shadow-lg"
      >
        {ctaLabel}
      </a>
    </div>
  </div>
</div>

<!-- ✅ Мобильная версия -->
<div class="flex flex-col items-start text-left p-8 md:hidden">

  <a
  href="https://www.google.com/maps/place/maxWapp+%7C+Juri+Lorenz/@48.0961726,11.5084223,17z/data=!3m1!5s0x479dd9218f79d1d3:0x204263009f086393!4m8!3m7!1s0xf3b4b557fd55469:0x893accd647bdc468!8m2!3d48.0961726!4d11.5084223!9m1!1b1!16s%2Fg%2F11wr1981wf?entry=ttu&g_ep=EgoyMDI1MDUwMy4wIKXMDSoJLDEwMjExNDU1SAFQAw%3D%3D"
  target="_blank"
  rel="noopener noreferrer"
  class="flex flex-col items-start mb-6 rounded-lg p-2">
  <div class="flex items-center">
    <div class="text-orange-200 ">
      ★ ★ ★ ★ ★
    </div>
    <div class="text-gray-300 ml-2">
       5.0
    </div>
  </div>
  <div class="text-gray-300 mt-1 underline">
    über 70 Bewertungen
  </div>
</a>
  <!-- Заголовок (mobile) -->
  <h1 class="text-5xl font-bold leading-tight">
    {title}<br />
    <span class="text-4xl">{subtitle}</span>
  </h1>

  <!-- Список преимуществ -->
  <ul class="text-lg mt-6 text-gray-100 space-y-2">
    {bulletsMobile.map((item) => (
      <li>
        <i class="fas fa-check text-white mr-4"></i>{item}
      </li>
    ))}
  </ul>

  <div
    class="flex flex-col md:flex-row gap-6 mt-12 md:mt-16 justify-center md:justify-start items-center md:items-start w-full md:w-auto"
  >
    <!-- Secondary Button -->

    <a
      href={ctaHref}
      class="relative inline-block py-4 px-10 rounded-full font-bold text-center w-full max-w-xs md:max-w-none md:w-auto bg-gradient-to-r from-purple-500 to-indigo-500 text-white shadow-md transition-all text-xl duration-300 ease-in-out"
    >
      {ctaLabel}
    </a>
  </div>

  <!-- Изображение (расположено ниже) -->
  <div class="mt-10">
    <img
      src={mobileImgSrc}
      class="w-full h-auto object-cover rounded-lg shadow-lg hero-image"
      alt={imgAlt}
      loading="eager"
      decoding="async"
    />
  </div>
</div>

<style>
  /* Only constrain the mobile hero headline */
  @media (max-width: 767px) {
    h1 {
      line-height: 1.2; /* Adjust line height for better spacing */
      max-width: 18ch; /* Prevents awkward breaking */
    }
  }
  .hero-image {
    position: relative;
    z-index: 1;
    mask-image: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 1) 70%,
      rgba(0, 0, 0, 0)
    );
    -webkit-mask-image: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 1) 70%,
      rgba(0, 0, 0, 0)
    ); /* Для Safari */
  }

  body {
    font-family: "Poppins", sans-serif;
  }
</style>
