---
// AnnaMenci.astro

import ContentSection from "../ContentSection.astro"
import VideoWithCTA from "../VideoWithCTA.astro"
import SectionTitle from "../SectionTitle.astro"
import GradientDivider from "../GradientDivider.astro"
import TextSection from "../TextSection.astro"
import FeatureCard from "../FeatureCard.astro"
import InfoBanner from "../InfoBanner.astro"
import ProjectCardsGrid from "../ProjectCardsGrid.astro"

---

<div class="project-component">
  <TextSection
    title="E-Commerce für Anna Menci"
    introText="Ein moderner Online-Shop für Anna Menci – eine exklusive Modemarke mit Fokus auf hochwertige Loungewear. Das minimalistische und elegante Design sorgt für eine perfekte User Experience."
    secondText="Mit einem nahtlosen Kaufprozess, optimierten Produktseiten und einer klaren Markenidentität hebt sich dieser Shop von der Konkurrenz ab."
  />

  <ContentSection
    imgSrc="/images/projects/anna-menci-kategorien.webp"
    imgAlt="Produktkategorie-Ansicht"
    title="Elegantes Shopping-Erlebnis"
    introText="Die Startseite bietet eine intuitive Navigation durch die verschiedenen Kategorien – klar strukturiert für eine einfache Produktauswahl."
    secondText="Das mobile-optimierte Design sorgt für eine reibungslose Nutzung auf allen Endgeräten und garantiert eine hohe Conversion-Rate."
  />

  <ContentSection
    imgSrc="/images/projects/anna-menci-longsleeve.webp"
    imgAlt="Produktdetailseite im Shop"
    title="Perfekt präsentierte Produkte"
    introText="Detaillierte Produktseiten mit hochwertigen Bildern, flexiblen Größenoptionen und direkter Kaufmöglichkeit – ein Shopping-Erlebnis, das überzeugt."
    secondText="Durch ansprechende Produktfotografie wird die Qualität der Kleidung hervorgehoben und das Interesse der Kunden gesteigert."
    reverse={true}
  />

  <ContentSection
    imgSrc="/images/projects/anna-menci-kontakt.webp"
    imgAlt="Kontakt- und Checkout-Bereich"
    title="Schneller Support & Kontakt"
    introText="Kunden können einfach über verschiedene Kanäle Kontakt aufnehmen – WhatsApp, E-Mail oder Telegram – für eine schnelle und persönliche Beratung."
    secondText="Der Checkout-Prozess ist schlank und effizient, um den Kaufabschluss so einfach wie möglich zu gestalten."
  />

  <ContentSection
    imgSrc="/images/projects/anna-menci-menu.webp"
    imgAlt="Menüansicht der Website"
    title="Minimalistisches UI-Design"
    introText="Das Hauptmenü ist clean und benutzerfreundlich – mit direktem Zugriff auf den Shop, die Galerie und Kontaktmöglichkeiten."
    secondText="Die Farbgebung und Typografie spiegeln die Exklusivität der Marke wider und schaffen ein kohärentes Markenbild."
    reverse={true}
  />

<SectionTitle title="Shop Features" />

<div class="grid grid-cols-1 md:grid-cols-2 gap-12 mt-24 mb-32">

  <FeatureCard
    title="Eleganter Fashion-Online-Shop"
    description="Minimalistisches Design und hochwertige Bildsprache präsentieren die Produkte stilvoll und stärken die Markenwirkung."
  />

  <FeatureCard
    title="Conversion-optimierte Produktseiten"
    description="Klare Struktur, große Produktbilder und intuitive Kaufbuttons sorgen für eine einfache und schnelle Kaufentscheidung."
  />

  <FeatureCard
    title="Mobile Shopping Experience"
    description="Der Shop wurde vollständig für Smartphones optimiert – schnelle Ladezeiten, intuitive Navigation und angenehme Nutzerführung."
  />

  <FeatureCard
    title="Direkte Kundenkommunikation"
    description="Kontaktmöglichkeiten über WhatsApp, E-Mail oder Telegram ermöglichen schnelle Beratung und erhöhen die Kaufwahrscheinlichkeit."
  />

</div>

<InfoBanner>
  Dieses Projekt zeigt, wie ein moderner <strong>Online-Shop</strong> für
  Fashion-Brands aufgebaut sein kann – mit klarem Design, starker
  Produktpräsentation und optimierter User Experience.
  Mehr dazu auf der Seite
  <a
    href="/online-shop-erstellen-lassen/"
    class="underline underline-offset-4 decoration-2 hover:text-white transition"
  >
    Online-Shop erstellen lassen
  </a>.
</InfoBanner>

<ProjectCardsGrid
  title="Ähnliche Projekte"
  items={[
    {
      href: "/projekte/louna-jewelry",
      district: "E-Commerce",
      title: "Louna Jewelry",
      description: "Online-Shop für handgefertigten Schmuck mit elegantem Design.",
    },
    {
      href: "/projekte/sweet-berry-box",
      district: "E-Commerce",
      title: "SweetBerryBox",
      description: "Online-Shop für Geschenkboxen mit modernem Design und klarer Struktur.",
    },
    {
      href: "/projekte/studio-d",
      district: "Beauty",
      title: "Studio D",
      description: "Website, Branding und Terminbuchung für ein Beauty-Studio.",
    },
  ]}
  cols={3}
  ctaLabel="Alle Projekte ansehen"
  ctaHref="/projekte"
  className="pt-0"
/>

  <GradientDivider />

  <SectionTitle title="Erlebe den Online-Shop in Aktion" />

  <VideoWithCTA
    videoSrc="https://www.youtube-nocookie.com/embed/KEseF_knapg?autoplay=1&modestbranding=1&showinfo=0&controls=1&rel=0"
    thumbnailSrc="/images/projects/anna-menci.webp"
    introText="Dieses Projekt kombiniert modernes Webdesign mit einer intuitiven Shopping-Experience. Perfekt für Brands, die online professionell auftreten möchten."
    ctaText="Möchtest du auch einen Online-Shop mit einzigartigem Design und perfekter Usability?"
    secondaryButtonLabel="Projekt anfragen"
    secondaryButtonLink="/kontakt"
  />
</div>
