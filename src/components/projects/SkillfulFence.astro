---
import ContentSection from "../ContentSection.astro"
import FeatureCard from "../FeatureCard.astro"
import IpadComponent from "../IpadComponent.astro"
import SectionTitle from "../SectionTitle.astro"
import GradientDivider from "../GradientDivider.astro"
import TextSection from "../TextSection.astro"
import FinalSection from "../FinalSection.astro"
---

<div class="project-component">

<p class="sr-only">
WordPress Website Referenz für ein internationales Handwerksunternehmen.
Dieses Projekt zeigt die Entwicklung einer modernen Website für ein Zaunbau-Unternehmen.
Responsives Webdesign, klare Struktur, Conversion-optimierte Inhalte und mobile Darstellung.
Webdesign Referenz umgesetzt von Webentwickler aus München.
</p>
  
  <TextSection
    introText="Für Skillful Fence wurde eine moderne WordPress Website entwickelt, die Leistungen, Referenzen und Kontaktmöglichkeiten klar präsentiert. Ziel war ein professioneller Online‑Auftritt für ein wachsendes Handwerksunternehmen im Raum Seattle."
    secondText="Das Projekt kombiniert klares Webdesign, strukturierte Inhalte und eine starke Conversion‑Strategie, damit Besucher schnell Vertrauen aufbauen und direkt eine Angebotsanfrage stellen können."
  />

  <IpadComponent
    imgSrc="/images/projects/fence-seattle-desktop-hero.webp"
    imgAlt="Hero Bereich der WordPress Website für ein Zaunbau-Unternehmen"
  />

    <TextSection
    introText="Die Website wurde vollständig responsiv umgesetzt und funktioniert auf Smartphone, Tablet und Desktop gleichermaßen intuitiv. Klare Call‑to‑Actions führen Besucher direkt zu einer Anfrage."
    secondText="Die Struktur der Seite sorgt dafür, dass Leistungen, Referenzen und Kontaktmöglichkeiten logisch aufgebaut sind – ideal für lokale Dienstleistungsunternehmen."
  />

  <ContentSection
    imgSrc="/images/projects/fence-seattle-mobile-cta-section.webp"
    imgAlt="Ansicht der Immobilien München Website auf dem Tablet"
    title="Conversion‑optimierte Landingpage"
    introText="Neben der klassischen Website wurde eine gezielte Landingpage erstellt, die auf lokale Suchanfragen rund um Fence Installation und Fence Contractors in Seattle optimiert ist."
    secondText="Durch strukturierte Inhalte, klare Überschriften und relevante Keywords entsteht eine SEO‑starke Seite, die langfristig Sichtbarkeit in Suchmaschinen aufbauen kann."
  />

    <ContentSection
    imgSrc="/images/projects/fence-seattle-mobile-content-section.webp"
    imgAlt="Footer mit Kontaktinformationen und Rechtstexten"
    title="Promo‑Video für mehr Aufmerksamkeit"
    introText="Für die Website wurde zusätzlich ein kurzes Promo‑Video integriert, das typische Projekte und die Qualität der Arbeit zeigt."
    secondText="Videos erhöhen die Verweildauer auf der Website und vermitteln Besuchern schneller Vertrauen in das Unternehmen und seine Leistungen."
    reverse={true}
  />

  <SectionTitle title="Website Highlights" />

  <IpadComponent
    imgSrc="/images/projects/fence-seattle-desktop-services.webp"
    imgAlt="Leistungsübersicht der Zaunbau Website"
  />

  <TextSection
    introText="Die Leistungsseite präsentiert verschiedene Zauntypen wie Holz‑, Vinyl‑ und Metallzäune sowie individuelle Lösungen für private und gewerbliche Grundstücke."
    secondText="Klare Struktur, große Bilder und kurze Erklärungstexte helfen Besuchern schnell die passende Lösung zu finden."
  />

  <ContentSection
    imgSrc="/images/projects/fence-seattle-mobile-quality-section.webp"
    imgAlt="Ansicht der Immobilien München Website auf dem Tablet"
    title="SEO‑optimierte Inhalte"
    introText="Die Website enthält gezielt aufgebaute Content‑Bereiche mit relevanten Suchbegriffen rund um Fence Installation, Residential Fencing und Custom Fence Solutions."
    secondText="Solche inhaltlich starken Seiten helfen dabei, langfristig organische Sichtbarkeit bei Google aufzubauen und neue Kunden über die Suche zu gewinnen."
  />

      <ContentSection
    imgSrc="/images/projects/fence-seattle-mobile-about-section.webp"
    imgAlt="Footer mit Kontaktinformationen und Rechtstexten"
    title="Unternehmensprofil & Vertrauen"
    introText="Eine eigene About‑Section stellt das Unternehmen, seine Erfahrung und Arbeitsweise vor."
    secondText="Authentische Inhalte und echte Projektbilder schaffen Vertrauen und unterstützen die Entscheidung potenzieller Kunden."
    reverse={true}
  />

  <SectionTitle title="Kontakt & Standort" />

  <IpadComponent
    imgSrc="/images/projects/fence-seattle-desktop-contact.webp"
    imgAlt="Kontaktformular und Standortübersicht auf dem Tablet"
  />

  <TextSection
    introText="Der Kontaktbereich ermöglicht eine schnelle Anfrage für neue Projekte – telefonisch, per E‑Mail oder direkt über das Formular."
  />

  <SectionTitle title="Features der Website" />

  <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mt-24 mb-32">
    <FeatureCard
      title="WordPress CMS"
      description="Die Website basiert auf WordPress und kann vom Unternehmen einfach selbst gepflegt und erweitert werden."
    />

    <FeatureCard
      title="Portfolio & Projektgalerien"
      description="Referenzprojekte werden in übersichtlichen Galerien präsentiert und zeigen die Vielfalt der realisierten Zaunlösungen."
    />

    <FeatureCard
      title="Landingpage für lokale SEO"
      description="Eine speziell strukturierte Landingpage unterstützt die Sichtbarkeit für lokale Suchanfragen rund um Fence Installation in Seattle."
    />

    <FeatureCard
      title="Mobile‑optimiertes Design"
      description="Die Website wurde vollständig für mobile Nutzung optimiert – schnell, übersichtlich und mit klaren Handlungsaufforderungen."
    />
  </div>

  <GradientDivider />

  <FinalSection
    imgSrc="/images/projects/fence-seattle-mobile-services.webp"
    imgAlt="Immobilien Website Screenshot"
    title="Website für dein Unternehmen?"
    introText="Eine klare Struktur, starke Inhalte und modernes Design machen den Unterschied, wenn Kunden online nach Dienstleistungen suchen."
    secondText="Ich entwickle performante Websites für Unternehmen und lokale Dienstleister – schnell, responsiv und SEO‑optimiert."
    secondaryButtonLabel="Projekt anfragen"
    secondaryButtonLink="/kontakt"
  />

</div>
