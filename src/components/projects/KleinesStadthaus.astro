---
import ContentSection from "../ContentSection.astro"
import InfoBanner from "../InfoBanner.astro"
import GradientDivider from "../GradientDivider.astro"
import TextSection from "../TextSection.astro"
import FinalSection from "../FinalSection.astro"
import FeatureCard from "../FeatureCard.astro"
import SectionTitle from "../SectionTitle.astro"
import ProjectCardsGrid from "../ProjectCardsGrid.astro"

---

<div class="project-component">
  <TextSection
    title="Shopify-Redesign für Kleines Stadthaus"
    introText="Ein vollständiger Redesign für den Shopify-Shop von 'Kleines Stadthaus – Lieblingsteile'. Ziel war es, ein harmonisches und modernes Layout zu schaffen, das sowohl funktional als auch visuell überzeugt."
    secondText="Inklusive Integration eines Instagram-Moduls, überarbeitetem Layout, verbesserten Produktseiten und einem stärkeren Markenauftritt."
  />

  <ContentSection
    imgSrc="/images/projects/kleines-stadthaus-bestsellers.webp"
    imgAlt="Startseiten-Layout im neuen Design"
    title="Startseite mit Charakter"
    introText="Die neue Startseite bietet sofortige Orientierung und eine klare visuelle Struktur. CTA-Bereiche und Kollektionen sind prominent platziert."
    secondText="Durch gezielte Farbwahl und Typografie wurde das Branding gefestigt und ein einheitliches Look & Feel geschaffen."
  />

  <ContentSection
    imgSrc="/images/projects/kleines-stadthaus-cardigan.webp"
    imgAlt="Produktdarstellung"
    title="Produktseiten optimiert für Conversion"
    introText="Die neuen Produktseiten fokussieren sich auf hochwertige Bilder und klar lesbare Preisgestaltung."
    secondText="Die Call-to-Action-Buttons wurden hervorgehoben, um den Kaufprozess intuitiver zu gestalten."
    reverse={true}
  />

  <ContentSection
    imgSrc="/images/projects/kleines-stadthaus-kollektionen.webp"
    imgAlt="Navigation und Menü"
    title="Benutzerfreundliche Navigation"
    introText="Das Menü wurde neu strukturiert, um den Zugang zu Produkten, Informationen und Kontaktmöglichkeiten zu erleichtern."
    secondText="Die mobile Navigation ist besonders intuitiv und klar gehalten."
  />

  <ContentSection
    imgSrc="/images/projects/kleines-stadthaus-instagram-integration.webp"
    imgAlt="Instagram Feed Integration"
    title="Instagram als Teil des Designs"
    introText="Mit einem leichtgewichtigen Modul werden aktuelle Instagram-Posts automatisch in den Shop integriert."
    secondText="So entsteht eine direkte Verbindung zwischen Social Media und Shopping-Erlebnis."
    reverse={true}
  />

  <SectionTitle title="Besondere Features" />

  <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mt-24 mb-32">

  <FeatureCard
    title="Shopify Redesign mit klarer Struktur"
    description="Der bestehende Shop wurde vollständig überarbeitet – mit moderner Navigation, klarer Seitenstruktur und besserer Nutzerführung."
  />

  <FeatureCard
    title="Website Relaunch für mehr Conversion"
    description="Produktseiten, Call-to-Actions und Layout wurden gezielt optimiert, damit Besucher schneller zum Kauf gelangen."
  />

  <FeatureCard
    title="Optimierte Mobile Experience"
    description="Der Relaunch wurde stark auf mobile Nutzung ausgerichtet – mit klarer Navigation, großen Bildern und intuitiver Bedienung."
  />

  <FeatureCard
    title="Stärkeres Branding im Online Shop"
    description="Farben, Typografie und Bildsprache wurden vereinheitlicht, um einen konsistenten und hochwertigen Markenauftritt zu schaffen."
  />

</div>

<InfoBanner>
  Dieses Projekt zeigt, wie ein <strong>Shopify-Redesign</strong> in der Praxis
  aussehen kann – mit moderner Gestaltung, klarer Struktur und optimierten
  Produktseiten für mehr Conversion.
  Mehr dazu auf der Seite
  <a
    href="/website-relaunch-redesign/"
    class="underline underline-offset-4 decoration-2 hover:text-white transition"
  >
    Website-Relaunch & Redesign
  </a>.
</InfoBanner>

<ProjectCardsGrid
  title="Ähnliche Projekte"
  items={[
    {
      href: "/projekte/louna-jewelry",
      district: "E-Commerce",
      title: "Louna Jewelry",
      description: "Online-Shop für handgefertigten Schmuck mit elegantem Design.",
    },
    {
      href: "/projekte/anna-menci",
      district: "Fashion",
      title: "Anna Menci",
      description: "Eleganter Fashion Online-Shop mit klarer Markenpräsentation.",
    },
    {
      href: "/projekte/sweet-berry-box",
      district: "E-Commerce",
      title: "SweetBerryBox",
      description: "Online-Shop für Geschenkboxen mit modernem Design und klarer Struktur.",
    },
  ]}
  cols={3}
  ctaLabel="Alle Projekte ansehen"
  ctaHref="/projekte"
  className="pt-0"
/>

  <GradientDivider />



  <FinalSection
    imgSrc="/images/projects/kleines-stadthaus-florentine-cardigan.webp"
    imgAlt="Call to Action Vorschau"
    title="Bereit für ein neues Shop-Erlebnis?"
    introText="Du möchtest auch deinem Shop ein neues Gesicht verleihen? "
    secondText="Ich unterstütze dich dabei – mit Strategie, Design und technischer Umsetzung."
    secondaryButtonLabel="Projekt anfragen"
    secondaryButtonLink="/kontakt"
  />
</div>
