---
interface Testimonial {
  name: string
  position: string
  company: string
  photo: string
  text: string
}

const testimonials: Testimonial[] = [
  {
    name: "Stephan Rauscher",
    position: "GF",
    company: "1 Line Architecture GmbH",
    photo: "/images/testimonials/stephan-rauscher.webp",
    text: "Juri von maxWapp hat für unser Architekturbüro 1 Line Architecture GmbH eine moderne, responsive Portfolio-Website entwickelt, auf der wir unsere Architektur-Projekte perfekt präsentieren können. Als Webdesigner in München arbeitet er schnell, zuverlässig und mit viel Liebe zum Detail, er nimmt Anregungen unmittelbar auf und setzt diese gekonnt um. Wer eine professionelle Website erstellen lassen möchte, dem kann ich Juri uneingeschränkt empfehlen."
  },
  {
    name: "Robert Maher",
    position: "GF",
    company: "Immobilien München GmbH",
    photo: "/images/testimonials/robert-maher.webp",
    text: "Juri hat für uns die Website für Immobilien München komplett neu gestaltet - mit einem klaren Design, perfekter mobiler Darstellung und professioneller Umsetzung. \n\nSchnelle Kommunikation und zuverlässige Arbeit.\n\n Sehr empfehlenswert!"
  },
  {
    name: "Doris Petrakovic",
    position: "GF",
    company: "Studio D",
    photo: "/images/testimonials/doris-petrakovic.webp",
    text: `Juri von maxWapp hat für mein Studio ein rundum perfektes Branding-Paket entwickelt – vom stilvollen Logo über elegante Visitenkarten bis hin zu einer modernen und benutzerfreundlichen Website.

Besonders begeistert bin ich von der klaren Struktur, dem hochwertigen Design und der Integration von Planity – so können unsere Kund:innen ganz einfach online Termine buchen und bezahlen.`
  },
  {
    name: "Helmut Grötschel",
    position: "GF",
    company: "Heizung • Sanitär • Solar",
    photo: "/images/testimonials/helmut-groetschel.webp",
    text: "Wir sind mit der Zusammenarbeit mit maxWapp / Juri Lorenz sehr zufrieden. Unsere Website wurde professionell überarbeitet, technisch optimiert und für Google sichtbar gemacht. Besonders positiv: die klare Struktur, schnelle Umsetzung und kompetente Beratung beim Website-Relaunch und bei der SEO-Optimierung. \n\nEin verlässlicher Partner für Webdesign und Website-Optimierung im Raum München. Sehr empfehlenswert!"
  }
]
---

<section class="pt-10 md:pt-14 pb-24 md:pb-28 text-white">
    <div class="section-container">
    <h2 class="mw-h2-compact text-center mb-12 md:mb-14">
      Kundenstimmen
    </h2>

    <div class="mw-glass-card relative py-12 md:py-14 md:mx-auto md:w-11/12 lg:w-9/12 text-center overflow-hidden">
      <div class="mw-topbar-gradient"></div>

      {testimonials.map((_, i) => (
        <input type="radio" id={`t-${i}`} name="testimonial" class="hidden peer" checked={i === 0} />
      ))}

      <div class="relative testimonial-wrap" id="testimonial-slider">
        {testimonials.map((t) => (
          <div class="testimonial transition-opacity duration-500 ease-in-out">
            <div class="flex flex-col md:flex-row items-center justify-center gap-8 md:gap-12 px-4 md:px-10">
              <div class="mw-profile-ring shrink-0">
                <div class="rounded-full bg-[#090a1a] p-0">
                  <img
                    src={t.photo}
                    alt={t.name}
                    class="rounded-full w-40 h-40 md:w-56 md:h-56 object-cover"
                  />
                </div>
              </div>

              <div class="text-center md:text-left max-w-xl">
                <div class="relative">
                  <span class="absolute -top-6 -left-3 text-8xl md:text-9xl md:-top-9 md:-left-7 text-purple-300 opacity-50 select-none">“</span>
                  <p class="mw-body text-gray-300 mb-6 whitespace-pre-line relative z-10">{t.text}</p>
                </div>
                <p class="text-lg font-bold text-white">{t.name}</p>
                <p class="text-sm text-gray-400">{t.position}, {t.company}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="flex justify-center gap-3 mt-10 relative z-10">
        {testimonials.map((_, i) => (
          <label
            for={`t-${i}`}
            class="dot w-3 h-3 rounded-full cursor-pointer bg-gray-500 hover:bg-white transition-all duration-300"
          ></label>
        ))}
      </div>
    </div>
  </div>

  <style>
    .testimonial-wrap {
      min-height: 460px;
      position: relative;
    }

    @media (max-width: 768px) {
      .testimonial-wrap {
        min-height: 700px;
      }
    }

    .testimonial {
      position: absolute;
      inset: 0;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.6s ease-in-out;
    }

    input#t-0:checked ~ .relative .testimonial:nth-of-type(1),
    input#t-1:checked ~ .relative .testimonial:nth-of-type(2),
    input#t-2:checked ~ .relative .testimonial:nth-of-type(3),
    input#t-3:checked ~ .relative .testimonial:nth-of-type(4) {
      opacity: 1;
      pointer-events: auto;
      position: absolute;
    }

    input#t-0:checked ~ div label[for="t-0"],
    input#t-1:checked ~ div label[for="t-1"],
    input#t-2:checked ~ div label[for="t-2"],
    input#t-3:checked ~ div label[for="t-3"] {
      background-color: white;
      transform: scale(1.3);
      opacity: 1;
    }

    label.dot {
      opacity: 0.6;
    }

    label.dot:hover {
      opacity: 1;
    }

    @media (max-width: 768px) {
      .testimonial {
        padding: 0 1rem;
      }

      .testimonial img {
        width: 9rem;
        height: 9rem;
      }

      .testimonial p {
        font-size: 1rem;
      }
    }
  </style>
<script>
  const slider = document.getElementById('testimonial-slider');
  const radios = document.querySelectorAll('input[name="testimonial"]') as NodeListOf<HTMLInputElement>;

  let startX = 0;
  let currentIndex = 0;

  // get current checked index
  function getCurrentIndex() {
    return Array.from(radios).findIndex(r => r.checked);
  }

  function setIndex(index) {
    if (index < 0) index = radios.length - 1;
    if (index >= radios.length) index = 0;
    radios[index].checked = true;
  }

  if (slider) {
    slider.addEventListener('touchstart', (e) => {
      startX = e.touches[0].clientX;
      currentIndex = getCurrentIndex();
    });

    slider.addEventListener('touchend', (e) => {
      const endX = e.changedTouches[0].clientX;
      const diff = startX - endX;

      // threshold to avoid accidental taps
      if (Math.abs(diff) < 40) return;

      if (diff > 0) {
        // swipe left → next
        setIndex(currentIndex + 1);
      } else {
        // swipe right → prev
        setIndex(currentIndex - 1);
      }
    });
  }
</script>
</section>