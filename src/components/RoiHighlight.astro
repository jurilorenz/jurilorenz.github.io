---
const {
  text = `Eine <strong>professionelle Website</strong> ist keine Ausgabe, sondern eine Investition,
die sich durch neue Kunden, bessere Sichtbarkeit und Vertrauen mehrfach auszahlt.`,
  href = "/kontakt",
  pillSmall = "Heute investieren",
  pillBig = "morgen mehr Anfragen &amp; Umsatz",
} = Astro.props;
---

<section class="section-container section-pad-compact pt-0 md:pt-0">
  <div class="max-w-4xl mx-auto text-center">
    <div class="mw-glass-card relative rounded-[24px] p-6 md:p-8 overflow-hidden">
      <div class="mw-topbar-gradient"></div>

      <p class="mw-body max-w-3xl mx-auto mb-8" set:html={text}></p>

      <a href={href} class="inline-block">
        <div class="roi-pill">
          <span class="roi-pill-small">{pillSmall}</span>
          <span class="roi-pill-arrow" aria-hidden="true">→</span>
          <span class="roi-pill-big" set:html={pillBig}></span>
        </div>
      </a>
    </div>
  </div>
</section>

<style>
  .roi-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.9rem 1.6rem;
    border-radius: 9999px;
    background: linear-gradient(
      to right,
      rgb(var(--mw-grad-from)),
      rgb(var(--mw-grad-to))
    );
    box-shadow: 0 0 14px rgba(147, 112, 219, 0.25);
    transition:
      filter 0.25s ease,
      box-shadow 0.25s ease;
  }

  .roi-pill:hover {
    filter: brightness(1.08);
    box-shadow: 0 0 22px rgba(147, 112, 219, 0.35);
  }

  .roi-pill-small {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.85);
  }

  .roi-pill-big {
    font-size: 1.05rem;
    font-weight: 700;
    color: #ffffff;
  }

  .roi-pill-arrow {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.95);
    animation: roiArrow 1.8s ease-in-out infinite;
  }

  @media (min-width: 768px) {
    .roi-pill-big {
      font-size: 1.15rem;
    }
  }

  @keyframes roiArrow {
    0%,
    100% {
      transform: translateX(0);
    }
    50% {
      transform: translateX(4px);
    }
  }

  .mw-glass-card {
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
    border: 1px solid rgba(255,255,255,0.08);
    transform: none;
  }

  .mw-glass-card:hover {
    transform: none;
    border-color: rgba(255,255,255,0.18);
    box-shadow: 0 0 40px rgba(99,102,241,0.12);
  }

  /* Override global card hover for this component */
  .mw-glass-card {
    border-color: rgba(255,255,255,0.16);
    box-shadow: 0 0 28px rgba(99,102,241,0.12);
    transition: none;
  }

  .mw-glass-card:hover {
    transform: none !important;
    border-color: rgba(255,255,255,0.16) !important;
    box-shadow: 0 0 28px rgba(99,102,241,0.12) !important;
  }
</style>