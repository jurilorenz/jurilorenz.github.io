---
// IpadComponent.astro
export interface IpadComponentProps {
  imgSrc: string;
  imgAlt: string;
  loading?: 'lazy' | 'eager';
  sizes?: string;
  width?: number;
  height?: number;
  className?: string;
}

const {
  imgSrc,
  imgAlt,
  loading = 'lazy',
  sizes = '(min-width:1024px) 60vw, (min-width:768px) 80vw, 100vw',
  width,
  height,
  className = 'rounded-lg w-full h-auto object-contain',
} = Astro.props as IpadComponentProps;
---

<section class="relative mt-12">
  <div
    class="
      mt-2 relative 
      w-screen 
      -ml-[calc((100vw-100%)/2)] 
      drop-shadow-[0px_-35px_35px_rgba(75,0,130,0.6)]
      sm:w-full sm:ml-auto sm:mr-auto sm:max-w-6xl
    "
  >
    <img
      src={imgSrc}
      alt={imgAlt}
      loading={loading}
      decoding="async"
      sizes={sizes}
      width={width}
      height={height}
      fetchpriority={loading === 'eager' ? 'high' : undefined}
      class={className}
    />
  </div>
</section>