---
import PrimaryButton from "./PrimaryButton.astro";

type Step = {
  num?: string;
  title: string;
  text: string;
};

type Props = {
  id?: string;
  eyebrow?: string;
  title: string;
  intro: string;
  steps: Step[];
  ctaLabel?: string;
  ctaHref?: string;
  showCta?: boolean;
  className?: string;
};

const {
  id,
  eyebrow,
  title,
  intro,
  steps,
  ctaLabel,
  ctaHref,
  showCta,
  className,
} = Astro.props as Props;

const hasCta =
  (showCta ?? true) &&
  typeof ctaLabel === "string" &&
  ctaLabel.trim().length > 0 &&
  typeof ctaHref === "string" &&
  ctaHref.trim().length > 0;
---

<section
  id={id}
  class={`relative w-full py-24 md:py-32 overflow-hidden ${(className ?? "")}`.trim()}
>
  <!-- Advanced background (blends with the page gradient, adds depth) -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <!-- Central radial focus (leans to the right where the headline is) -->
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_40%,rgba(168,85,247,0.22),transparent_60%)]"></div>

    <!-- Secondary glow -->
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_80%,rgba(99,102,241,0.16),transparent_55%)]"></div>

    <!-- Large ambient blobs -->
    <div class="absolute -top-56 left-1/2 -translate-x-1/2 w-[1100px] h-[1100px] rounded-full bg-purple-500/10 blur-[180px]"></div>
    <div class="absolute -bottom-56 right-[-10%] w-[900px] h-[900px] rounded-full bg-indigo-500/10 blur-[180px]"></div>

    <!-- Subtle vertical blend (prevents banding) -->
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-black/10"></div>

    <!-- Subtle noise texture (premium depth) -->
    <div class="absolute inset-0 opacity-[0.04] mix-blend-overlay mw-noise"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-6 md:px-12">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-14 items-start">
      <!-- LEFT: Steps (2/3) -->
      <div class="md:col-span-7 order-2 md:order-1">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 md:gap-8">
          {steps.map((s, idx) => (
            <article class="mw-step-card group">
              <div class="mw-step-topbar" aria-hidden="true"></div>

              <div class="flex items-start gap-4">
                <div class="mw-step-badge" aria-hidden="true">
                  {s.num ?? String(idx + 1)}
                </div>

                <div>
                  <h3 class="text-xl md:text-2xl font-bold text-white">
                    {s.title}
                  </h3>
                  <p class="mt-3 text-base md:text-lg text-gray-300 leading-relaxed">
                    {s.text}
                  </p>
                </div>
              </div>

              <div class="mw-step-glow" aria-hidden="true"></div>
            </article>
          ))}
        </div>
      </div>

      <!-- RIGHT: Heading + Intro + CTA (1/3) -->
      <div class="md:col-span-5 order-1 md:order-2 text-center md:text-left">

        {eyebrow && (
          <p class="mw-eyebrow mb-3">
            {eyebrow}
          </p>
        )}

        <h2
          class="mt-4 text-4xl md:text-6xl font-extrabold leading-[1.12] md:leading-[1.12] tracking-tight text-white"
        >
          {title}
        </h2>

        <p class="mt-6 text-lg md:text-2xl text-gray-300 leading-relaxed max-w-[46ch] md:max-w-none">
          {intro}
        </p>

        {hasCta && (
          <div class="mt-10 flex flex-col gap-4 items-center md:items-start">
            <PrimaryButton href={ctaHref!} label={ctaLabel!} />
          </div>
        )}
      </div>
    </div>
  </div>
</section>