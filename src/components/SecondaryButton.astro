---
interface Props {
  href: string
  label: string
  variant?: "gradient" | "white"
  fullWidth?: boolean
  target?: "_self" | "_blank"
  rel?: string
  className?: string
  ariaLabel?: string
  id?: string
}

const {
  href,
  label,
  variant = "white",
  fullWidth = false,
  target = "_self",
  rel = target === "_blank" ? "noopener noreferrer" : undefined,
  className = "",
  ariaLabel,
  id,
} = Astro.props

const variantClasses =
  variant === "gradient"
    ? "bg-gradient-to-r from-[rgb(var(--mw-grad-from))] to-[rgb(var(--mw-grad-to))] text-white shadow-[0_10px_30px_rgba(99,102,241,0.25)] hover:brightness-110 hover:shadow-[0_15px_40px_rgba(99,102,241,0.35)]"
    : "border border-white/15 bg-white/5 text-gray-100 hover:border-[rgba(147,112,219,0.55)] hover:bg-white/8 hover:shadow-[0_0_40px_rgba(147,112,219,0.18)]"
---

<a
  id={id}
  href={href}
  target={target}
  rel={rel}
  aria-label={ariaLabel ?? label}
  class={`inline-flex items-center justify-center px-10 py-4 rounded-full font-bold text-lg text-center
  ${fullWidth ? "w-full max-w-xs" : "w-auto"}
  transition-all duration-300 ease-in-out
  ${variantClasses}
  ${className}`}
>
  {label}
</a>